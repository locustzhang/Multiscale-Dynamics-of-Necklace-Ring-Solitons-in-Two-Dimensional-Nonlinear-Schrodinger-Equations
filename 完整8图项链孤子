# 收敛测试
# -----------------------------------------------------------------------------
def run_convergence_test():
    print("\n" + "="*60)
    print("[Convergence Test] dt sweep + Nx sweep")
    print("="*60)
    base_cfg = dict(Lx=25.0, Ly=25.0, T=CONV_T, g=G_SINGLE, V_trap=V_TRAP_SINGLE)
    dt_results = []

    print("\n  [dt sweep] Nx=512 fixed, computing reference solution first")
    # 用列表中最细的 dt 作参考解，循环只跑更粗的点，避免自比为零
    dt_ref = CONV_DT_LIST[-1]   # 2e-5
    cfg_ref = SimConfig(Nx=512, Ny=512, dt=dt_ref, **base_cfg)
    sol_ref = GPESolver(cfg_ref)
    psi0_ref = sol_ref.necklace_initial()
    dat_ref = sol_ref.run(psi0_ref, f'conv_ref_dt{dt_ref:.0e}',
                          save_fields=False, n_save=NSAVE_CONVERGENCE)
    psi_ref = dat_ref['psi_final'].copy()
    ref_norm = np.linalg.norm(psi_ref)
    del sol_ref, psi0_ref, dat_ref
    if DEVICE.type == 'cuda':
        torch.cuda.empty_cache()
        torch.cuda.synchronize()

    # 只对比比参考解更粗的点，不含 dt_ref 自身
    for dt in CONV_DT_LIST[:-1]:   # [2e-4, 1e-4, 5e-5]，跳过 2e-5
        cfg = SimConfig(Nx=512, Ny=512, dt=dt, **base_cfg)
        sol = GPESolver(cfg)
        psi0 = sol.necklace_initial()
        dat = sol.run(psi0, f'conv_dt{dt:.0e}',
                      save_fields=False, n_save=NSAVE_CONVERGENCE)
        psi_np = dat['psi_final'].copy()

        # 相位对齐 + 误差计算
        prod = np.vdot(psi_ref, psi_np)
        phase = np.angle(prod)
        psi_aligned = psi_np * np.exp(-1j * phase)
        sol_err = np.linalg.norm(psi_aligned - psi_ref) / (ref_norm + 1e-30)

        print(f"    dt={dt:.0e}  E_err={dat['max_E_err']:.2e}  sol_err={sol_err:.2e}")
        dt_results.append({
            'dt': float(dt),
            'E_err': float(dat['max_E_err']),
            'N_err': float(dat['max_N_err']),
            'sol_err': float(sol_err)
        })
        del sol, psi0, dat, psi_np
        if DEVICE.type == 'cuda':
            torch.cuda.empty_cache()

    # 空间收敛测试
    nx_results = []
    print("\n  [Nx sweep] dt = C*dx^2 (isolate spatial error)")
    for nx in CONV_NX_LIST:
        dx_nx = 2 * 25.0 / nx
        dt_nx = CONV_C_CFL * dx_nx**2
        cfg = SimConfig(Nx=nx, Ny=nx, dt=dt_nx, **base_cfg)
        sol = GPESolver(cfg)
        psi = sol.necklace_initial()
        dat = sol.run(psi, f'conv_nx{nx}', save_fields=False, n_save=NSAVE_CONVERGENCE)
        nx_results.append({
            'Nx': nx,
            'dx': cfg.dx,
            'dt': dt_nx,
            'E_err': float(dat['max_E_err']),
            'N_err': float(dat['max_N_err'])
        })
        del sol, psi, dat
        if DEVICE.type == 'cuda':
            torch.cuda.empty_cache()

    res = {'dt_results': dt_results, 'nx_results': nx_results}
    with open(f'{OUTPUT_DIR}/convergence.json', 'w') as f:
        json.dump(res, f, indent=2)
    print("[Convergence Test] done.")
    return res


