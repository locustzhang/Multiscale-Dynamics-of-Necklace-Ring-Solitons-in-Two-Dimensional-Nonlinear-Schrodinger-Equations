               label=r'Solution error $\|\psi_{\Delta t}-\psi_\mathrm{ref}\|/\|\psi_\mathrm{ref}\|$')

    # 拟合
    mask = sol_errs > 1e-15
    if np.sum(mask) >= 2:
        slope_dt, intercept_dt = np.polyfit(
            np.log10(dts[mask]), np.log10(sol_errs[mask]), 1)
        dt_fit = np.geomspace(dts[mask].min(), dts[mask].max(), 80)
        ax1.loglog(dt_fit, 10**intercept_dt * dt_fit**slope_dt, '--',
                   color=C['grey'], lw=1.2,
                   label=fr'Fit slope $\approx {slope_dt:.2f}$')

    # O(dt^2) 参考线
    ref2 = sol_errs[0] * (dts / dts[0])**2
    ax1.loglog(dts, ref2, ':', color=C['red'], lw=1.2,
               label=r'$\mathcal{O}(\Delta t^2)$ ref.')

    ax1.set_xlabel(r'Time step $\Delta t$')
    ax1.set_ylabel('Solution error')
    ax1.legend(fontsize=9)
    style_ax(ax1)
    panel_label(ax1, 'a')

    # ---- 右图：空间收敛（不变）----
    dxs = np.array([r['dx'] for r in conv_res['nx_results']])
    e_nx = np.array([r['E_err'] for r in conv_res['nx_results']])

    idx_sort_x = np.argsort(dxs)[::-1]
    dxs = dxs[idx_sort_x]
    e_nx = e_nx[idx_sort_x]

    ax2.loglog(dxs, e_nx, 's-', color=C['red'], lw=1.8, ms=7,
               label='Energy error')

    if len(dxs) >= 2:
        slope_nx, intercept_nx = np.polyfit(
            np.log10(dxs), np.log10(e_nx + 1e-30), 1)
        dx_fit = np.geomspace(dxs.min(), dxs.max(), 100)
        ax2.loglog(dx_fit, 10**intercept_nx * dx_fit**slope_nx, '--',
                   color=C['grey'], lw=1.2,
                   label=fr'Fit slope $\approx {slope_nx:.2f}$')

    ref2x = e_nx[0] * (dxs / dxs[0])**2
    ax2.loglog(dxs, ref2x, ':', color=C['blue'], lw=1.2,
               label=r'$\mathcal{O}(\Delta x^2)$ ref.')

    ax2.set_xlabel(r'Grid spacing $\Delta x$')
    ax2.set_ylabel(r'Max rel. energy error $|\Delta E/E_0|$')
    ax2.legend(fontsize=9)
    style_ax(ax2)
    panel_label(ax2, 'b')

    fig.suptitle('Fig. 5. Convergence test: temporal and spatial', fontsize=14)
    fig.savefig(f'{OUTPUT_DIR}/Fig5_Convergence.pdf', bbox_inches='tight')
    plt.close()
    print("[Fig5] saved.")

