def _count_peaks_2d(rho: np.ndarray):
    rho_s = ndimage.gaussian_filter(rho, sigma=GAUSSIAN_SMOOTH_SIGMA)
    maxima = np.zeros_like(rho_s, dtype=bool)
    maxima[1:-1, 1:-1] = ((rho_s[1:-1, 1:-1] > rho_s[:-2, 1:-1]) &
                          (rho_s[1:-1, 1:-1] > rho_s[2:, 1:-1]) &
                          (rho_s[1:-1, 1:-1] > rho_s[1:-1, :-2]) &
                          (rho_s[1:-1, 1:-1] > rho_s[1:-1, 2:]))
    threshold = PEAK_THRESH_REL * rho_s.max()
    peak_mask = maxima & (rho_s > threshold)
    y, x = np.where(peak_mask)
    peaks = list(zip(y, x))
    keep = []
    for p in peaks:
        if all(np.hypot(p[0] - q[0], p[1] - q[1]) > PEAK_MIN_DIST for q in keep):
            keep.append(p)
    return len(keep)

def _radial_correlation(rho_final: np.ndarray, rho_init: np.ndarray, R_flat: np.ndarray, Lx: float):
    r_bins = np.linspace(0, Lx, RADIAL_CORR_BINS + 1)
    def radial_mean(rho):
        flat = rho.ravel()
        hist, _ = np.histogram(R_flat, bins=r_bins, weights=flat)
        cnt, _ = np.histogram(R_flat, bins=r_bins)
        with np.errstate(divide='ignore', invalid='ignore'):
            return np.where(cnt > 0, hist / cnt, 0.0)
    r_fin = radial_mean(rho_final)
    r_ini = radial_mean(rho_init)
    denom = np.std(r_fin) * np.std(r_ini)
    if denom < 1e-20:
        return 0.0
    return float(np.corrcoef(r_fin, r_ini)[0, 1])

def classify_collision(dat, rho_init_np: np.ndarray, R_flat: np.ndarray, Lx: float, snap_files: list) -> dict:
    z_final = np.load(snap_files[-1])
    rho_final = np.abs(z_final) ** 2
    rho_ratio = float(dat['rho_ratio'])
    n_peaks = _count_peaks_2d(rho_final)
    r_corr = _radial_correlation(rho_final, rho_init_np, R_flat, Lx)
    if dat['collapsed']:
        ctype = 'collapse'
    elif n_peaks < int(N_PEAKS * FUSION_PEAKS) and rho_ratio > RHO_RATIO_FUSION:
        ctype = 'fusion'
    elif n_peaks > int(N_PEAKS * FRAGMENTATION_PEAKS) and r_corr < CORR_THRESH_FRAG:
        ctype = 'fragmentation'
    elif r_corr > CORR_THRESH_QE:
        ctype = 'quasi-elastic'
    else:
        ctype = 'inelastic'
    return {'type': ctype, 'rho_ratio': rho_ratio, 'n_peaks': n_peaks, 'radial_corr': r_corr}

def run_collision_scan():
    print("\n" + "="*60)
    print(f"[Collision Scan] v sweep: {COLL_V_LIST}")
    print("="*60)
    global COLL_COLORS
    COLL_COLORS['inelastic'] = '#4CAF50'
    results = []
    for v in COLL_V_LIST:
        label = f'coll_v{v:.2f}'
        cfg = SimConfig(Nx=NX_COLL, Ny=NY_COLL, Lx=LX_COLL, Ly=LY_COLL, dt=COLL_DT, T=COLL_T, g=G_COLL, V_trap=V_TRAP_COLL)
        sol = GPESolver(cfg)
