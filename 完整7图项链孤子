def run_1d_g_scan():
    """
    一维 g 扫描，固定 V_trap，看 rho_ratio 随 g 的变化。
    """
    print("\n" + "="*60)
    print(f"[1D g Scan] {SCAN_N_G} points")
    print("="*60)
    gs = np.linspace(SCAN_G_MIN, SCAN_G_MAX, SCAN_N_G)
    results = []
    for g in gs:
        label = f'1d_g{g:.3f}'
        cfg   = SimConfig(Nx=512, Ny=512, Lx=25.0, Ly=25.0,
                          dt=DT_DEFAULT, T=T_SINGLE,
                          g=float(g), V_trap=V_TRAP_SINGLE)
        sol   = GPESolver(cfg)
        psi   = sol.necklace_initial()
        dat   = sol.run(psi, label, save_fields=False, n_save=100)
        results.append({
            'g':         float(g),
            'rho_ratio': float(dat['rho_ratio']),
            'E_err':     float(dat['max_E_err']),
            'N_over_Ncr': float(dat['N0'] / cfg.N_cr),
            'collapse_metric': float(dat['collapse_metric'][-1]),
        })
        print(f"  g={g:.3f} → rho_ratio={dat['rho_ratio']:.3f}, "
              f"N/Ncr={dat['N0']/cfg.N_cr:.3f}")
        del sol, psi
        if DEVICE.type == 'cuda': torch.cuda.empty_cache()
    with open(f'{OUTPUT_DIR}/scan1d.json', 'w') as f:
        json.dump(results, f, indent=2)
    print("[1D Scan] done.")
    return results


def fig4_stability(single_data, scan1d, cfg):
    """
    Fig 4：径向稳定性 + 1D g 扫描。
    左：径向密度的时空演化（r vs t）
    右：rho_ratio 随 g 的变化
    """
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))
    plt.subplots_adjust(wspace=0.25)

    # --- 左：径向时空演化 ---
    snap_files = single_data['snap_files']
    t_arr      = single_data['t']
    n_snap     = len(snap_files)
    n_r        = 120
    r_arr      = np.linspace(0, cfg.Lx, n_r)
    rho_rt     = np.zeros((n_r, n_snap))
    
    # ✅ 性能修复：只创建一次 solver，避免反复构造
    solver_tmp = GPESolver(cfg)
    for i, f in enumerate(snap_files):
        z    = np.load(f)
        rho  = np.abs(z)**2
        _, r_prof = solver_tmp.radial_profile(rho, n_bins=n_r)
        rho_rt[:, i] = r_prof

    im = ax1.pcolormesh(t_arr, r_arr, rho_rt,
                        cmap=plt.cm.magma,
                        norm=PowerNorm(gamma=0.5),
                        shading='auto')
    cb = plt.colorbar(im, ax=ax1)
    cb.set_label(r'Radial density $\rho(r)$', fontsize=11)
    cb.outline.set_visible(False)
    ax1.set_xlabel('Time $t$')
    ax1.set_ylabel('Radius $r$')
    ax1.set_title('Radial density evolution', fontsize=12)
    style_ax(ax1)
    panel_label(ax1, 'a')

    # --- 右：1D g 扫描 ---
    gs   = np.array([r['g']         for r in scan1d])
    rr   = np.array([r['rho_ratio'] for r in scan1d])
    nocr = np.array([r['N_over_Ncr'] for r in scan1d])
    ax2.plot(gs, rr, 'o-', color=C['blue'], lw=1.8, ms=6)
    ax2_twin = ax2.twinx()
    ax2_twin.plot(gs, nocr, 's--', color=C['grey'], lw=1.0, ms=4, alpha=0.6,
                  label=r'$N/N_\mathrm{cr}$')
    ax2.set_xlabel(r'Interaction strength $g$')
    ax2.set_ylabel(r'$\rho_\mathrm{max}(T)/\rho_\mathrm{max}(0)$')
    ax2_twin.set_ylabel(r'$N/N_\mathrm{cr}$', color=C['grey'])
    ax2_twin.tick_params(axis='y', labelcolor=C['grey'])
    ax2.set_title('1D stability scan', fontsize=12)
    style_ax(ax2)
    panel_label(ax2, 'b')

    fig.suptitle('Fig. 4. Radial stability and interaction dependence', fontsize=14)
    fig.savefig(f'{OUTPUT_DIR}/Fig4_Stability.pdf', bbox_inches='tight')
    plt.close()
    print("[Fig4] saved.")


