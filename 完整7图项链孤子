# =============================================================================
# SimConfig
# =============================================================================
@dataclass
class SimConfig:
    Nx: int   = 512
    Ny: int   = 512
    Lx: float = 25.0
    Ly: float = 25.0
    dt: float = DT_DEFAULT
    T:  float = 6.0
    N_peaks: int   = N_PEAKS
    R_ring:  float = R_RING
    A_peak:  float = A_PEAK
    w_peak:  float = W_PEAK
    g:       float = -0.08
    V_trap:  float = 0.0
    Omega:   float = OMEGA_ROT
    seed:    int   = SEED
    dtype_real: torch.dtype = torch.float64
    dtype_cplx: torch.dtype = torch.complex128

    def __post_init__(self):
        self.dx = 2 * self.Lx / self.Nx
        self.dy = 2 * self.Ly / self.Ny
        self.x  = (torch.arange(self.Nx, device=DEVICE, dtype=self.dtype_real)
                   - self.Nx // 2) * self.dx
        self.y  = (torch.arange(self.Ny, device=DEVICE, dtype=self.dtype_real)
                   - self.Ny // 2) * self.dy

    @property
    def N_cr(self):
        # Townes threshold（仅对无势均匀空间成立，有 trap 时仅供参考）
        return 5.85 / abs(self.g)

    def validate(self, N_total: float) -> dict:
        # ✅ 修复：SSFM 无条件稳定，这里是色散尺度参考，不是 CFL 稳定条件
        dispersion_scale = self.dx**2 / (2 * np.pi**2)
        nl_phase  = abs(self.g) * (self.A_peak**2) * self.dt
        return {
            'dispersion_scale_satisfied':    self.dt < dispersion_scale,
            'dt_over_dispersion_scale':      self.dt / dispersion_scale,
            'NL_phase_per_step': nl_phase,
            'N_total':          N_total,
            'N_cr':             self.N_cr,
            'collapse_safe':    N_total < self.N_cr,
            'N_over_Ncr':       N_total / self.N_cr,
        }

    def print_config(self):
        print(f"  Config : Nx={self.Nx}, Ny={self.Ny}, L={self.Lx}, dx={self.dx:.4f}")
        print(f"  Soliton: N_peaks={self.N_peaks}, R={self.R_ring}, "
              f"g={self.g}, V_trap={self.V_trap}")
        print(f"  Precision: float64 + complex128")
        print(f"  N_cr={self.N_cr:.4f} (uniform, no-trap reference)")

# =============================================================================
# SnapshotManager
# =============================================================================
class SnapshotManager:
    def __init__(self, base_dir: str, label: str):
        self.snap_dir   = os.path.join(base_dir, f"Snapshots_{label}")
        os.makedirs(self.snap_dir, exist_ok=True)
        self.saved_files: List[str] = []

    def save(self, psi: torch.Tensor):
        fname = f"snap_{len(self.saved_files):05d}.npy"
        path  = os.path.join(self.snap_dir, fname)
        # ✅ 保留 complex128，不降精度
        np.save(path, psi.detach().cpu().numpy().astype(np.complex128))
        self.saved_files.append(path)

    def load(self, idx: int) -> np.ndarray:
        return np.load(self.saved_files[min(idx, len(self.saved_files)-1)],
                       mmap_mode='r')

# =============================================================================
# GPESolver
# =============================================================================
class GPESolver:
    def __init__(self, cfg: SimConfig):
        self.cfg = cfg
        self.X, self.Y = torch.meshgrid(cfg.x, cfg.y, indexing='ij')
        kx = torch.fft.fftfreq(cfg.Nx, d=cfg.dx).to(DEVICE, dtype=torch.float64) * 2*np.pi
        ky = torch.fft.fftfreq(cfg.Ny, d=cfg.dy).to(DEVICE, dtype=torch.float64) * 2*np.pi
        self.KX, self.KY = torch.meshgrid(kx, ky, indexing='ij')
        self.K2        = self.KX**2 + self.KY**2
        self.V         = 0.5 * cfg.V_trap * (self.X**2 + self.Y**2)
        
        # ✅ 修复：明确写出 1/2 系数，符合标准 GPE 形式，避免歧义
        # 标准 GPE: iψ_t = -1/2 ∇²ψ + ...
        # 线性传播子: exp(-i * (1/2)k² * dt/2) = exp(-i k² dt/4)
        self.prop_half = torch.exp((-1j) * 0.5 * self.K2 * (cfg.dt / 2)).to(torch.complex128)
        
        self.R_cpu     = torch.sqrt(self.X**2 + self.Y**2).detach().cpu().numpy()
        self.R_flat    = self.R_cpu.ravel()

    def necklace_initial(self) -> torch.Tensor:
        cfg  = self.cfg
        psi  = torch.zeros((cfg.Nx, cfg.Ny), dtype=torch.complex128, device=DEVICE)
        angs = torch.linspace(0, 2*np.pi, cfg.N_peaks+1, device=DEVICE)[:-1]
        for th in angs:
            x0  = cfg.R_ring * torch.cos(th)
            y0  = cfg.R_ring * torch.sin(th)
            r2  = (self.X - x0)**2 + (self.Y - y0)**2
            psi += cfg.A_peak * torch.exp(-r2 / cfg.w_peak**2)
        if cfg.Omega != 0:
            psi *= torch.exp(1j * cfg.Omega * torch.atan2(self.Y, self.X))
        return psi

    def two_ring_collision(self, R1=7.0, R2=11.0, v=1.5) -> torch.Tensor:
        """
        两环碰撞初态。
        包络：以各峰中心为参考的高斯函数。
        相位：e^{±ivR}，R 为到原点的径向距离，
              内环 +v（向外扩散），外环 -v（向内收缩）。
        
        ⚠ 物理说明：这里的 v 是**径向相位印记参数**，对应入射动量，
        论文中建议表述为 "incident momentum parameter (v)" 或 "radial phase imprint"，
        避免审稿人误解为严格的物理速度。
        """
        cfg      = self.cfg
        psi      = torch.zeros_like(self.X, dtype=torch.complex128, device=DEVICE)
        angs     = torch.linspace(0, 2*np.pi, cfg.N_peaks+1, device=DEVICE)[:-1]
        R_origin = torch.sqrt(self.X**2 + self.Y**2 + 1e-12)  # ✅ 相位参考到原点
        for th in angs:
            x0 = R1 * torch.cos(th);  y0 = R1 * torch.sin(th)
            r2 = (self.X - x0)**2 + (self.Y - y0)**2
            psi += cfg.A_peak * torch.exp(-r2 / cfg.w_peak**2) * torch.exp( 1j*v*R_origin)
            x0 = R2 * torch.cos(th);  y0 = R2 * torch.sin(th)
            r2 = (self.X - x0)**2 + (self.Y - y0)**2
            psi += cfg.A_peak * torch.exp(-r2 / cfg.w_peak**2) * torch.exp(-1j*v*R_origin)
        return psi

    @torch.no_grad()
    def diagnostics(self, psi):
        cfg   = self.cfg
        rho   = torch.abs(psi)**2
        N     = torch.sum(rho).item() * cfg.dx * cfg.dy
        rho_max = torch.max(rho).item()

        psi_k = torch.fft.fft2(psi, norm="ortho")
        dpx   = torch.fft.ifft2(psi_k * (1j * self.KX), norm="ortho")
        dpy   = torch.fft.ifft2(psi_k * (1j * self.KY), norm="ortho")
        del psi_k

        Ekin  = 0.5 * torch.sum(torch.abs(dpx)**2 + torch.abs(dpy)**2).item() * cfg.dx*cfg.dy
        Eint  = 0.5 * cfg.g * torch.sum(rho**2).item() * cfg.dx*cfg.dy
        Etrap = torch.sum(self.V * rho).item() * cfg.dx*cfg.dy
        Etot  = Ekin + Eint + Etrap
        Lz    = torch.sum(torch.conj(psi)*(-1j)*(self.X*dpy - self.Y*dpx)).real.item() \
                * cfg.dx*cfg.dy
        del dpx, dpy
        
        # ✅ 网格无关的崩塌度量
        collapse_metric = rho_max * cfg.dx * cfg.dy
        return Etot, Ekin, Eint, Etrap, N, Lz, rho_max, collapse_metric

    @torch.no_grad()
    def step(self, psi):
        psi_k = torch.fft.fft2(psi, norm="ortho")
        psi_k.mul_(self.prop_half)
        psi   = torch.fft.ifft2(psi_k, norm="ortho");  del psi_k

        rho = torch.abs(psi)**2
        psi.mul_(torch.exp((-1j) * self.cfg.dt * (self.cfg.g * rho + self.V)))

        psi_k = torch.fft.fft2(psi, norm="ortho")
        psi_k.mul_(self.prop_half)
        psi   = torch.fft.ifft2(psi_k, norm="ortho");  del psi_k
        return psi

    def radial_profile(self, rho_np, n_bins=120):
        r_bins  = np.linspace(0, self.cfg.Lx, n_bins+1)
        rho_r,_ = np.histogram(self.R_flat, bins=r_bins,
                               weights=rho_np.ravel())
        cnt,_   = np.histogram(self.R_flat, bins=r_bins)
        with np.errstate(divide='ignore', invalid='ignore'):
            rho_r = np.divide(rho_r, cnt, where=cnt > 0)
        return 0.5*(r_bins[:-1]+r_bins[1:]), rho_r

    def run(self, psi0, label="sim", save_fields=True, n_save=200):
        cfg      = self.cfg
        steps    = int(cfg.T / cfg.dt)
        interval = max(1, steps // n_save)
        psi      = psi0.clone()
        snap     = SnapshotManager(OUTPUT_DIR, label) if save_fields else None

        E0,_,_,_,N0,Lz0,rho0,cm0 = self.diagnostics(psi)
        stab = cfg.validate(N0)
        print(f"\n[{label}] N0={N0:.4f}, N/Ncr={stab['N_over_Ncr']:.4f} | "
              f"{'SAFE' if stab['collapse_safe'] else 'UNSAFE'}")

        data = dict(t=[], E=[], E_kin=[], E_int=[], E_trap=[],
                    N=[], Lz=[], rho_max=[], collapse_metric=[],
                    E_err=[], N_err=[], Lz_err=[],
                    max_E_err=0, max_N_err=0, max_Lz_err=0,
                    E0=E0, N0=N0, Lz0=Lz0, stab=stab,
                    collapsed=False, label=label)

        pbar = tqdm(range(steps), desc=label, colour='blue')
        for i in pbar:
            psi = self.step(psi)
            if i % interval == 0:
                E,Ek,Ei,Et,N,Lz,rho_max,cm = self.diagnostics(psi)
                data['t'].append(i*cfg.dt)
                data['E'].append(E);       data['E_kin'].append(Ek)
                data['E_int'].append(Ei);  data['E_trap'].append(Et)
                data['N'].append(N);       data['Lz'].append(Lz)
                data['rho_max'].append(rho_max)
                data['collapse_metric'].append(cm)
                data['E_err'].append(abs(E-E0)/(abs(E0)+1e-30))
                data['N_err'].append(abs(N-N0)/(abs(N0)+1e-30))
                data['Lz_err'].append(abs(Lz-Lz0))   # 绝对误差，避免 Lz0≈0 时发散
                if save_fields: snap.save(psi)
                
                # ✅ 修复：双判据崩塌检测，网格无关
                if (rho_max > 100*rho0) or (cm > 25):
                    data['collapsed'] = True; break
                    
                pbar.set_postfix(E=f"{data['E_err'][-1]:.1e}",
                                 N=f"{data['N_err'][-1]:.1e}")
            if i % 4000 == 0 and DEVICE.type == 'cuda':
                torch.cuda.empty_cache()

        if save_fields:
            snap.save(psi)
            data['snap_files'] = snap.saved_files
        else:
            data['snap_files'] = []
        pbar.close()

        for k in ['t','E','E_kin','E_int','E_trap','N','Lz',
                  'rho_max','collapse_metric','E_err','N_err','Lz_err']:
            data[k] = np.array(data[k])
        data['max_E_err']  = data['E_err'].max()
        data['max_N_err']  = data['N_err'].max()
        data['max_Lz_err'] = data['Lz_err'].max()
        data['rho_ratio']  = data['rho_max'][-1] / data['rho_max'][0]
        # ✅ 返回末态波函数，供收敛性测试计算解误差，避免重复推进
        data['psi_final']  = psi.detach().cpu().numpy()

        print(f"  Max ΔE/E0={data['max_E_err']:.2e}  "
              f"ΔN/N0={data['max_N_err']:.2e}  "
              f"|ΔLz|={data['max_Lz_err']:.2e}  "
              f"ρ_ratio={data['rho_ratio']:.3f}")
        return data

# =============================================================================
# 新增模块 A：收敛性测试
# =============================================================================
def run_convergence_test():
    """
    对 dt 和 Nx 分别做收敛测试，验证二阶收敛率。
    参考解：最细 dt/Nx 对应的守恒量误差。
    
    注：若需严格的空间收敛阶，需将不同网格的解插值到同一网格计算解误差，
    当前版本已保证时间收敛严格二阶，空间收敛通过 dt∝dx² 隔离主导误差。
    """
    print("\n" + "="*60)
    print("[Convergence Test] dt sweep + Nx sweep")
    print("="*60)

    base_cfg = dict(Lx=25.0, Ly=25.0, T=CONV_T,
                    g=G_SINGLE, V_trap=V_TRAP_SINGLE)

    # --- dt 收敛：固定 Nx=512，同时记录守恒量误差 + 解误差 ---
    # 参考解：最细 dt（CONV_DT_LIST 最后一个），在 T=CONV_T 时刻的波函数
    dt_results  = []
    psi_ref     = None   # 参考波函数（最细 dt）
    print("\n  [dt sweep] Nx=512 fixed, computing reference solution first")

    # 1. 参考解：最细 dt，用 run() 统一产生，collapse 机制与其他 dt 一致
    dt_ref  = CONV_DT_LIST[-1]
    cfg_ref = SimConfig(Nx=512, Ny=512, dt=dt_ref, **base_cfg)
    sol_ref = GPESolver(cfg_ref)
    psi0_ref = sol_ref.necklace_initial()
    dat_ref  = sol_ref.run(psi0_ref, f'conv_ref_dt{dt_ref:.0e}',
                           save_fields=False, n_save=20)
    psi_ref  = dat_ref['psi_final']   # shape (Nx, Ny), complex128
    del sol_ref, psi0_ref
    if DEVICE.type == 'cuda': torch.cuda.empty_cache()

    # 2. 各粗 dt：用同一个 run()，解误差直接取 psi_final，不重复推进
    for dt in CONV_DT_LIST:
        cfg  = SimConfig(Nx=512, Ny=512, dt=dt, **base_cfg)
        sol  = GPESolver(cfg)
        psi0 = sol.necklace_initial()
        dat  = sol.run(psi0, f'conv_dt{dt:.0e}', save_fields=False, n_save=50)

        # ✅ 修复：相位对齐误差，消除全局相位自由度
        psi_np = dat['psi_final']
        prod = np.vdot(psi_ref, psi_np)
        phase = np.angle(prod)
        psi_aligned = psi_np * np.exp(-1j * phase)
        sol_err = np.linalg.norm(psi_aligned - psi_ref) / (np.linalg.norm(psi_ref) + 1e-30)

        dt_results.append({'dt':      dt,
                           'E_err':   float(dat['max_E_err']),
                           'N_err':   float(dat['max_N_err']),
                           'sol_err': float(sol_err)})
        print(f"    dt={dt:.0e}  E_err={dat['max_E_err']:.2e}  "
              f"sol_err={sol_err:.2e}")
        del sol, psi0
        if DEVICE.type == 'cuda': torch.cuda.empty_cache()

    # --- Nx 收敛：dt ∝ dx²，保证时间误差远小于空间误差，孤立空间收敛阶 ---
    # C_cfl 选取保证最粗网格 dt 仍满足色散尺度，最细网格 dt 足够小
    C_cfl      = 0.05   # dt = C_cfl * dx^2
    nx_results = []
    print("\n  [Nx sweep] dt = C*dx^2 (isolate spatial error)")
    for nx in CONV_NX_LIST:
        dx_nx = 2 * 25.0 / nx
        dt_nx = C_cfl * dx_nx**2          # dt 随 dx^2 缩小，时间误差 O(dt^2)=O(dx^4) 可忽略
        cfg   = SimConfig(Nx=nx, Ny=nx, dt=dt_nx, **base_cfg)
        sol   = GPESolver(cfg)
        psi   = sol.necklace_initial()
        dat   = sol.run(psi, f'conv_nx{nx}', save_fields=False, n_save=50)
        nx_results.append({'Nx': nx, 'dx': cfg.dx, 'dt': dt_nx,
                           'E_err': float(dat['max_E_err']),
                           'N_err': float(dat['max_N_err'])})
        del sol, psi
