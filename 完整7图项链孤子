def fig_convergence(conv_res):
    """
    Fig 5：收敛性测试。
    左：max|ΔE/E0| vs dt（对数-对数，拟合斜率应≈2）
    右：max|ΔE/E0| vs dx（对数-对数，拟合斜率应≈2）
    """
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(11, 5))
    plt.subplots_adjust(wspace=0.30)

    # --- dt 收敛 ---
    dts      = np.array([r['dt']      for r in conv_res['dt_results']])
    e_dt     = np.array([r['E_err']   for r in conv_res['dt_results']])
    sol_errs = np.array([r['sol_err'] for r in conv_res['dt_results']])

    ax1.loglog(dts, e_dt, 'o-', color=C['blue'], lw=1.8, ms=7,
               label=r'Conservation error $|\Delta E/E_0|$')
    ax1.loglog(dts, sol_errs, '^-', color=C['teal'], lw=1.8, ms=7,
               label=r'Solution error $\|\psi_{\Delta t}-\psi_\mathrm{ref}\|/\|\psi_\mathrm{ref}\|$')

    # 拟合解误差斜率（更严格的收敛阶）
    slope_dt, intercept_dt = np.polyfit(np.log10(dts),
                                         np.log10(sol_errs+1e-30), 1)
    dt_fit = np.geomspace(dts.min(), dts.max(), 80)
    ax1.loglog(dt_fit, 10**intercept_dt * dt_fit**slope_dt,
               '--', color=C['grey'], lw=1.2,
               label=fr'Fit slope $\approx {slope_dt:.2f}$')
    # 参考二阶线
    ref2 = sol_errs[-1] * (dts / dts[-1])**2
    ax1.loglog(dts, ref2, ':', color=C['red'], lw=1.2,
               label=r'$\mathcal{O}(\Delta t^2)$ ref.')
    ax1.set_xlabel(r'Time step $\Delta t$')
    ax1.set_ylabel('Error')
    ax1.legend(fontsize=8)
    style_ax(ax1)
    panel_label(ax1, 'a')

    # --- Nx 收敛 ---
    dxs  = np.array([r['dx']    for r in conv_res['nx_results']])
    e_nx = np.array([r['E_err'] for r in conv_res['nx_results']])
    ax2.loglog(dxs, e_nx, 's-', color=C['red'], lw=1.8, ms=7, label='Energy error')
    slope_nx, intercept_nx = np.polyfit(np.log10(dxs), np.log10(e_nx+1e-30), 1)
    dx_fit = np.linspace(dxs.min(), dxs.max(), 100)
    ax2.loglog(dx_fit, 10**intercept_nx * dx_fit**slope_nx,
               '--', color=C['grey'], lw=1.2,
               label=fr'Fit slope $\approx {slope_nx:.2f}$')
    ref2x = e_nx[-1] * (dxs / dxs[-1])**2
    ax2.loglog(dxs, ref2x, ':', color=C['blue'], lw=1.2, label=r'$\mathcal{O}(\Delta x^2)$ ref.')
    ax2.set_xlabel(r'Grid spacing $\Delta x$')
    ax2.set_ylabel(r'Max rel. energy error $|\Delta E/E_0|$')
    ax2.legend(fontsize=9)
    style_ax(ax2)
    panel_label(ax2, 'b')

    fig.suptitle('Fig. 5. Convergence test: temporal and spatial', fontsize=14)
    fig.savefig(f'{OUTPUT_DIR}/Fig5_Convergence.pdf', bbox_inches='tight')
    plt.close()
    print("[Fig5] saved.")

