# =============================================================================
def _count_peaks_2d(rho: np.ndarray, min_dist=18, threshold_rel=0.30) -> int:
    """
    超级稳健峰值计数：
    1. 强高斯平滑去掉干涉条纹噪声
    2. 只保留真实局部极大值
    3. 最小距离过滤，避免噪声碎峰
    专门给项链孤子碰撞用，永远不会出 100+ 假峰
    """
    # 强平滑，彻底消除干涉波纹
    rho_s = ndimage.gaussian_filter(rho, sigma=2.5)
    
    # 2D 局部极大值
    maxima = np.zeros_like(rho_s, dtype=bool)
    maxima[1:-1, 1:-1] = (
        (rho_s[1:-1, 1:-1] > rho_s[:-2, 1:-1]) &
        (rho_s[1:-1, 1:-1] > rho_s[2:, 1:-1]) &
        (rho_s[1:-1, 1:-1] > rho_s[1:-1, :-2]) &
        (rho_s[1:-1, 1:-1] > rho_s[1:-1, 2:])
    )
    
    # 阈值：只保留足够强的峰
    threshold = threshold_rel * rho_s.max()
    peak_mask = maxima & (rho_s > threshold)
    y, x = np.where(peak_mask)
    
    # 按最小距离去重，避免噪声多峰
    peaks = list(zip(y, x))
    keep = []
    for p in peaks:
        if all(np.hypot(p[0]-q[0], p[1]-q[1]) > min_dist for q in keep):
            keep.append(p)
    return len(keep)


def _radial_correlation(rho_final: np.ndarray, rho_init: np.ndarray,
                         R_flat: np.ndarray, Lx: float, n_bins=80) -> float:
    """
    计算末态与初态径向密度分布的 Pearson 相关系数。
    = 1 → 结构完全保留（quasi-elastic）
    → 0 或负 → 结构显著改变（fusion / fragmentation）
    """
    r_bins = np.linspace(0, Lx, n_bins + 1)

    def radial_mean(rho):
        flat   = rho.ravel()
        hist,_ = np.histogram(R_flat, bins=r_bins, weights=flat)
        cnt,_  = np.histogram(R_flat, bins=r_bins)
        with np.errstate(divide='ignore', invalid='ignore'):
            return np.where(cnt > 0, hist / cnt, 0.0)

    r_fin = radial_mean(rho_final)
    r_ini = radial_mean(rho_init)
    denom = np.std(r_fin) * np.std(r_ini)
    if denom < 1e-20:
        return 0.0
    return float(np.corrcoef(r_fin, r_ini)[0, 1])


def classify_collision(dat, rho_init_np: np.ndarray,
                        R_flat: np.ndarray, Lx: float,
                        snap_files: list) -> dict:
    """
    多指标碰撞分类，返回包含类别和所有指标的 dict。

    指标：
      1. collapsed  — 数值/物理崩塌
      2. fusion     — 峰数减半 + 密度增强
      3. fragmentation — 峰数翻倍 + 结构相关性低
      4. quasi-elastic: 结构几乎完全保留
      5. inelastic    : 其余（有形变但未碎裂）
    """
    # 末态波函数
    z_final    = np.load(snap_files[-1])
    rho_final  = np.abs(z_final) ** 2

    rho_ratio  = float(dat['rho_ratio'])
    n_peaks    = _count_peaks_2d(rho_final)
    r_corr     = _radial_correlation(rho_final, rho_init_np, R_flat, Lx)

    if dat['collapsed']:
        ctype = 'collapse'
    elif n_peaks < N_PEAKS // 2 and rho_ratio > 2.0:
        ctype = 'fusion'
    # ✅ 修复：fragmentation 判据，避免把扩散误判为碎裂
    elif n_peaks > N_PEAKS * 2 and r_corr < 0.5:
        ctype = 'fragmentation'
    elif r_corr > 0.85:
        ctype = 'quasi-elastic'
    else:
        ctype = 'inelastic'

    return {'type': ctype, 'rho_ratio': rho_ratio,
            'n_peaks': n_peaks, 'radial_corr': r_corr}


def run_collision_scan():
    """
    扫描入射速度 v，对每个 v 运行双环碰撞，记录多指标分类结果。
    """
    print("\n" + "="*60)
    print(f"[Collision Scan] v sweep: {COLL_V_LIST}")
    print("="*60)

    # 新增碰撞类别颜色（含 inelastic）
    global COLL_COLORS
    COLL_COLORS['inelastic'] = '#4CAF50'

    results = []
    for v in COLL_V_LIST:
        label = f'coll_v{v:.2f}'
        cfg   = SimConfig(Nx=512, Ny=512, Lx=LX_COLL, Ly=LY_COLL,
                          dt=COLL_DT, T=COLL_T, g=G_COLL, V_trap=V_TRAP_COLL)
        sol   = GPESolver(cfg)
        psi   = sol.two_ring_collision(v=v)

        # 保存初态密度（numpy），供分类函数计算径向相关
        rho_init_np = (torch.abs(psi)**2).detach().cpu().numpy()

        dat   = sol.run(psi, label, save_fields=True, n_save=120)
        cls   = classify_collision(dat, rho_init_np,
                                    sol.R_flat, LX_COLL,
                                    dat['snap_files'])

        results.append({
            'v':           float(v),
            'type':        cls['type'],
            'rho_ratio':   cls['rho_ratio'],
            'n_peaks':     cls['n_peaks'],
            'radial_corr': cls['radial_corr'],
            'max_E_err':   float(dat['max_E_err']),
            'collapsed':   bool(dat['collapsed']),
            'snap_files':  dat['snap_files'],
            't':           dat['t'].tolist(),
            'rho_max':     dat['rho_max'].tolist(),
        })
        print(f"  v={v:.2f} → [{cls['type']}]  "
              f"rho_ratio={cls['rho_ratio']:.3f}  "
              f"n_peaks={cls['n_peaks']}  "
              f"r_corr={cls['radial_corr']:.3f}")
        del sol, psi
        if DEVICE.type == 'cuda': torch.cuda.empty_cache()

    # ✅ 修复：完整保存所有数据，包括 snap_files，保证缓存可用
    with open(f'{OUTPUT_DIR}/collision_scan.json', 'w') as f:
        json.dump(results, f, indent=2)
    print("[Collision Scan] done.")
    return results


