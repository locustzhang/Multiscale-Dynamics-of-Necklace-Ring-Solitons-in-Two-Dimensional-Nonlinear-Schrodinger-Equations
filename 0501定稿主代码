def run_1d_g_scan() -> list:
    print("\n" + "=" * 60)
    print(f"[1D g Scan] {SCAN_N_G} points in g ∈ [{SCAN_G_MIN}, {SCAN_G_MAX}]")
    print("=" * 60)
    gs_arr  = np.linspace(SCAN_G_MIN, SCAN_G_MAX, SCAN_N_G)
    results = []
    for g in gs_arr:
        label = f'1d_g{g:.3f}'
        cfg   = SimConfig(Nx=512, Ny=512, Lx=25.0, Ly=25.0,
                          dt=DT_DEFAULT, T=T_SINGLE,
                          g=float(g), V_trap=V_TRAP_SINGLE)
        sol   = GPESolver(cfg)
        psi   = sol.necklace_initial()
        dat   = sol.run(psi, label, save_fields=False, n_save=NSAVE_SCAN1D,
                        phi_nl_max=PHI_NL_MAX_SCAN)
        results.append({
            'g':               float(g),
            'rho_ratio':       float(dat['rho_ratio']),
            'E_err':           float(dat['max_E_err']),
            'N_over_Ncr_free': float(dat['N0'] / cfg.N_cr_free),
            'N_over_Ncr_trap': float(dat['N0'] / cfg.N_cr_trap),
            'N_cr_trap_valid': bool(cfg.N_cr_correction_valid),  # [C2]
        })
        validity = '' if cfg.N_cr_correction_valid else ' [Ncr EXTRAP]'
        print(f"  g={g:.3f}  rho_ratio={dat['rho_ratio']:.3f}  "
              f"N/Ncr(free)={results[-1]['N_over_Ncr_free']:.3f}  "
              f"N/Ncr(trap)={results[-1]['N_over_Ncr_trap']:.3f}{validity}")
        del sol, psi
        if DEVICE.type == 'cuda':
            torch.cuda.empty_cache()

    with open(f'{OUTPUT_DIR}/scan1d.json', 'w') as f:
        json.dump(results, f, indent=2)
    print("[1D Scan] done.")
    return results


def fig4_stability(single_data: dict, scan1d: list, cfg: SimConfig):
    t_arr      = single_data['t']
    snap_files = single_data['snap_files']
    n_frames   = len(snap_files)
    n_plot     = min(len(t_arr), n_frames)
    t_plot     = t_arr[:n_plot]
    n_r        = RADIAL_PROFILE_BINS
    r_arr      = np.linspace(0, cfg.Lx, n_r)
    rho_rt     = np.zeros((n_r, n_plot))

    sol_tmp = GPESolver(cfg)
    for i in range(n_plot):
        z            = np.load(snap_files[i])
        _, r_prof    = sol_tmp.radial_profile(np.abs(z) ** 2)
        rho_rt[:, i] = r_prof

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))
    plt.subplots_adjust(wspace=0.25)

    im = ax1.pcolormesh(t_plot, r_arr, rho_rt, cmap=plt.cm.magma,
                        norm=PowerNorm(gamma=0.5), shading='nearest')
    cb = plt.colorbar(im, ax=ax1)
    cb.set_label(r'Radial density $\rho(r,t)$', fontsize=11)
    cb.outline.set_visible(False)
    ax1.set_xlabel('Time $t$');  ax1.set_ylabel('Radius $r$')
    ax1.set_title('Radial density evolution', fontsize=12)
    style_ax(ax1);  panel_label(ax1, 'a')

    gs_plot    = np.array([r['g']               for r in scan1d])
    rr_plot    = np.array([r['rho_ratio']        for r in scan1d])
    nocr_free  = np.array([r['N_over_Ncr_free']  for r in scan1d])
    nocr_trap  = np.array([r['N_over_Ncr_trap']  for r in scan1d])
    # [C2] Mark extrapolated points
    valid_mask = np.array([r.get('N_cr_trap_valid', True) for r in scan1d])

    ax2.plot(gs_plot, rr_plot, 'o-', color=C['blue'], lw=1.8, ms=6,
             label=r'$\rho_\mathrm{max}$ ratio')
    ax2_t = ax2.twinx()
    ax2_t.plot(gs_plot, nocr_free, 's--', color=C['grey'],  lw=1.0, ms=4,
               alpha=0.6, label=r'$N/N_\mathrm{cr}^\mathrm{free}$ (lower bound)')
    # [C2] Valid points solid, extrapolated dashed with marker
    ax2_t.plot(gs_plot[valid_mask], nocr_trap[valid_mask],
               'D-', color=C['orange'], lw=1.0, ms=4, alpha=0.8,
               label=r'$N/N_\mathrm{cr}^\mathrm{trap}$ (valid)')
    if np.any(~valid_mask):
        ax2_t.plot(gs_plot[~valid_mask], nocr_trap[~valid_mask],
                   'D:', color=C['orange'], lw=1.0, ms=4, alpha=0.4,
                   label=r'$N/N_\mathrm{cr}^\mathrm{trap}$ (extrap.)')
    ax2_t.axhline(1.0, color='red', ls=':', lw=0.8, alpha=0.5)

    ax2.set_xlabel(r'Coupling constant $g$')
    ax2.set_ylabel(r'$\rho_\mathrm{max}(T)/\rho_\mathrm{max}(0)$')
    ax2_t.set_ylabel(r'$N/N_\mathrm{cr}$', color=C['grey'])
    ax2_t.tick_params(axis='y', labelcolor=C['grey'])
    lines1, labs1 = ax2.get_legend_handles_labels()
    lines2, labs2 = ax2_t.get_legend_handles_labels()
    ax2.legend(lines1 + lines2, labs1 + labs2, fontsize=8, loc='upper left')
    ax2.set_title('1D stability scan', fontsize=12)
    style_ax(ax2);  panel_label(ax2, 'b')

    fig.savefig(f'{OUTPUT_DIR}/Fig4_Stability.pdf',
                bbox_inches='tight', dpi=600)
    plt.close()
    print("[Fig4] saved.")


