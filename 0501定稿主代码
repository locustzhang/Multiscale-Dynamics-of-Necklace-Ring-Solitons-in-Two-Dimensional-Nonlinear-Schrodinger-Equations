# ── GPESolver ─────────────────────────────────────────────────────────────────
# =============================================================================

class GPESolver:
    """
    Split-step pseudo-spectral solver for the 2-D GPE.

    Time-stepping scheme (BAB Strang splitting, second-order)
    ---------------------------------------------------------
    Given ψ(t), one full step to ψ(t + dt):

        ψ̂  = FFT[ψ]
        ψ̂  ← ψ̂ · exp(−i K² dt/2)          ← kinetic half-step
        ψ  = IFFT[ψ̂]
        ρ  = |ψ|²                            ← density at step midpoint [C3]
        ψ  ← ψ · exp(−i dt [g ρ + V_eff])  ← nonlinear full-step
        ψ̂  = FFT[ψ]
        ψ̂  ← ψ̂ · exp(−i K² dt/2)          ← kinetic half-step
        ψ  = IFFT[ψ̂]

    The density ρ is evaluated at the step midpoint (after the first
    kinetic half-step), which is the correct prescription for the BAB
    form of Strang splitting and gives global second-order accuracy O(dt²).

    Rotating frame [C4]
    -------------------
    When Omega != 0 the effective nonlinear phase includes the term
        −Omega · L̂_z
    where L̂_z = −i(x∂_y − y∂_x).  The action of exp(−i dt Omega Lz)
    on ψ is implemented spectrally: Lz ψ is computed in Fourier space,
    giving spectral accuracy and consistency with the kinetic operator.

    The Lz operator in Fourier space reads (Shankar 1994):
        F[Lz ψ] = −i F[(x ∂_y − y ∂_x) ψ]
    We compute it as:
        Lz ψ = −i (x · IFFT[i ky · FFT[ψ]] − y · IFFT[i kx · FFT[ψ]])
             = x · ∂_y ψ − y · ∂_x ψ   (with spectral derivatives)

    Since Lz is a linear operator, it cannot be applied as a pointwise
    phase on ψ.  Instead we perform the nonlinear step as:
        ψ ← exp(−i dt [g|ψ|² + V_trap]) · ψ
    followed by a separate rotation step:
        ψ ← exp(−i dt Omega Lz) · ψ
    where the last operator is the angular rotation by angle (Omega·dt):
        [exp(−i α Lz) ψ](r, θ) = ψ(r, θ − α)
    This is implemented exactly by bilinear interpolation on the rotated
    grid, giving the correct rotating-frame dynamics without truncation
    error in Lz.  [C4]

    Conserved Hamiltonian in the rotating frame  [C4]
    -------------------------------------------------
    In the rotating frame the conserved quantity is not E_kin + E_int +
    E_trap but rather:
        H_rot = E_kin + E_int + E_trap − Omega · Lz
    The diagnostics() method returns H_rot when Omega != 0.
    """

    def __init__(self, cfg: SimConfig):
        self.cfg   = cfg
        self.X, self.Y = torch.meshgrid(cfg.x, cfg.y, indexing='ij')

        # Fourier wave-vectors
        kx = (torch.fft.fftfreq(cfg.Nx, d=cfg.dx)
              .to(DEVICE, dtype=torch.float64) * 2 * np.pi)
        ky = (torch.fft.fftfreq(cfg.Ny, d=cfg.dy)
              .to(DEVICE, dtype=torch.float64) * 2 * np.pi)
        self.KX, self.KY = torch.meshgrid(kx, ky, indexing='ij')
        self.K2 = self.KX ** 2 + self.KY ** 2

        # Trap potential
        self.V = 0.5 * cfg.V_trap * (self.X ** 2 + self.Y ** 2)

        # Kinetic half-step propagator (fixed for constant dt)
        self.prop_half = torch.exp(
            (-1j) * 0.25 * self.K2 * cfg.dt
        ).to(torch.complex128)

        # Radial coordinate on CPU for diagnostics
        self.R_cpu  = torch.sqrt(self.X ** 2 + self.Y ** 2).detach().cpu().numpy()
        self.R_flat = self.R_cpu.ravel()

        self._has_rotation = (cfg.Omega != 0.0)

        # [C4] Pre-compute spectral derivative operators for Lz (complex)
        self._iKX = (1j * self.KX).to(torch.complex128)
        self._iKY = (1j * self.KY).to(torch.complex128)

    # ── [C10] Boundary check ──────────────────────────────────────────────────

    def check_boundary(self, psi: torch.Tensor, label: str = "") -> bool:
        """
        Verify that |ψ| is negligible at the periodic domain boundary.

        The FFT assumes periodic boundary conditions.  The harmonic trap
        confines ψ to the interior, but if the trap is too weak or the
        domain too small, ψ may be non-negligible at the boundary, causing
        aliasing errors.  We check that

            max|ψ(boundary)| / max|ψ| < BOUNDARY_PSI_THRESH

        Returns True if the check passes.  [C10]
        """
        psi_np   = psi.detach().cpu().numpy()
        psi_abs  = np.abs(psi_np)
        psi_max  = psi_abs.max()
        if psi_max < 1e-30:
            return True
        # Boundary = first/last row and column
        boundary_max = max(
            psi_abs[0, :].max(),  psi_abs[-1, :].max(),
            psi_abs[:, 0].max(),  psi_abs[:, -1].max()
        )
        ratio = boundary_max / psi_max
        if ratio > BOUNDARY_PSI_THRESH:
            print(f"  ⚠️  [{label}] Boundary check FAILED: "
                  f"|ψ(boundary)|/|ψ_max| = {ratio:.2e} > {BOUNDARY_PSI_THRESH:.0e}. "
                  f"Increase domain size Lx or trap strength V_trap to avoid "
                  f"aliasing from the FFT periodic boundary condition.")
            return False
        return True

    # ── Initial conditions ────────────────────────────────────────────────────

    def necklace_initial(self) -> torch.Tensor:
        """
        N_peaks Gaussian bright solitons arranged on a ring of radius R_ring.
        """
        cfg  = self.cfg
        psi  = torch.zeros((cfg.Nx, cfg.Ny), dtype=torch.complex128, device=DEVICE)
        angs = torch.linspace(0, 2 * np.pi, cfg.N_peaks + 1, device=DEVICE)[:-1]
        for th in angs:
            x0  = cfg.R_ring * torch.cos(th)
            y0  = cfg.R_ring * torch.sin(th)
            r2  = (self.X - x0) ** 2 + (self.Y - y0) ** 2
            psi += cfg.A_peak * torch.exp(-r2 / cfg.w_peak ** 2)
        return psi

    def two_ring_collision(self, R1: float = 6.0, R2: float = 10.0,
                           k0: float = 0.5) -> torch.Tensor:
        """
        Two co-axial necklace rings with opposing radial momenta, producing
        a head-on collision at r ≈ (R1 + R2) / 2.

        Parameters
        ----------
        R1  : radius of the inner ring
        R2  : radius of the outer ring
        k0  : radial wave-vector imparted to each ring  [C1]
               Units: 1/length  (same unit system as the grid).
               Physical group velocity: v = ℏ k0 / m = k0 (ℏ=m=1 units).

        Phase prescription  [C1, FIX]
        ------------------------------
        The radial phase exp(±i k0 r_local) is applied using the LOCAL
        radial coordinate r_local = |r − r_peak_centre| for each peak,
        where r_peak_centre is the Gaussian centre of that peak.

        Using the global coordinate r = |r| (as in the original code)
        introduces non-physical phase gradients at peaks far from the
        origin, because the global radial direction does not align with
        the local outward direction at each peak position.  The local
        prescription ensures that each peak carries a momentum k0 purely
        in the radial direction at its own location, independent of where
        on the ring it sits.

        Inner ring: exp(+i k0 r_local)  → moving outward
        Outer ring: exp(−i k0 r_local)  → moving inward
        """
        cfg  = self.cfg
        psi  = torch.zeros_like(self.X, dtype=torch.complex128, device=DEVICE)
        angs = torch.linspace(0, 2 * np.pi, cfg.N_peaks + 1, device=DEVICE)[:-1]

        for th in angs:
            # Inner ring: outward momentum (+k0)
            x0 = R1 * torch.cos(th);  y0 = R1 * torch.sin(th)
            # [C1 FIX] local radial distance from peak centre
            r2_local = (self.X - x0) ** 2 + (self.Y - y0) ** 2
            r_local  = torch.sqrt(r2_local + 1e-30)
            psi += (cfg.A_peak * torch.exp(-r2_local / cfg.w_peak ** 2)
                    * torch.exp(1j * k0 * r_local))

            # Outer ring: inward momentum (−k0)
            x0 = R2 * torch.cos(th);  y0 = R2 * torch.sin(th)
            r2_local = (self.X - x0) ** 2 + (self.Y - y0) ** 2
            r_local  = torch.sqrt(r2_local + 1e-30)
            psi += (cfg.A_peak * torch.exp(-r2_local / cfg.w_peak ** 2)
                    * torch.exp(-1j * k0 * r_local))

        return psi

    # ── [C4] Spectral Lz operator ─────────────────────────────────────────────

    @torch.no_grad()
    def _apply_Lz_rotation(self, psi: torch.Tensor, angle: float) -> torch.Tensor:
        """
        Apply the rotation operator exp(−i angle Lz) to ψ.

        In position space, exp(−i α Lz) rotates the wave-function by
        angle α in the x-y plane:
            [exp(−i α Lz) ψ](r, θ) = ψ(r, θ − α)

        This is implemented by bilinear interpolation of ψ on the
        rotated coordinate grid, which is exact up to interpolation
        error (controlled by the grid resolution).  [C4]

        Parameters
        ----------
        psi   : wave-function on the (Nx, Ny) grid
        angle : rotation angle in radians (= Omega * dt)
        """
        if abs(angle) < 1e-15:
            return psi

        cfg = self.cfg
        # Rotated coordinates: (x', y') = R(-angle) (x, y)
        # where R(-angle) undoes the frame rotation
        cos_a = np.cos(angle)
        sin_a = np.sin(angle)

        # Grid coordinates in physical units
        X_rot = cos_a * self.X + sin_a * self.Y   # x' on rotated grid
        Y_rot = -sin_a * self.X + cos_a * self.Y  # y' on rotated grid

        # Map to normalised grid indices in [−1, 1] for grid_sample
        x_norm = X_rot / cfg.Lx   # in (−1, 1)
        y_norm = Y_rot / cfg.Ly

        # grid_sample expects grid of shape (N, Hy, Wx, 2) with (x, y) order
        grid = torch.stack([y_norm, x_norm], dim=-1).unsqueeze(0)

        # Interpolate real and imaginary parts separately (grid_sample is real)
        psi_r = psi.real.unsqueeze(0).unsqueeze(0)  # (1,1,Nx,Ny)
        psi_i = psi.imag.unsqueeze(0).unsqueeze(0)

        # Note: grid_sample uses (x=col, y=row) convention with align_corners
        r_rot = torch.nn.functional.grid_sample(
            psi_r.float(), grid.float(),
            mode='bilinear', padding_mode='zeros', align_corners=True
        ).squeeze().to(torch.float64)
        i_rot = torch.nn.functional.grid_sample(
            psi_i.float(), grid.float(),
            mode='bilinear', padding_mode='zeros', align_corners=True
        ).squeeze().to(torch.float64)

        return torch.complex(r_rot, i_rot)

    # ── Diagnostics ───────────────────────────────────────────────────────────

    @torch.no_grad()
    def _spectral_Lz(self, psi: torch.Tensor) -> torch.Tensor:
        """
        Compute L̂_z ψ = −i(x ∂_y − y ∂_x) ψ spectrally.

        Uses FFT derivatives for spectral accuracy, consistent with the
        kinetic energy operator.  [C4]

        Returns Lz_psi (complex tensor, same shape as psi).
        """
        psi_k  = torch.fft.fft2(psi, norm="ortho")
        dpsi_x = torch.fft.ifft2(self._iKX * psi_k, norm="ortho")  # ∂_x ψ
        dpsi_y = torch.fft.ifft2(self._iKY * psi_k, norm="ortho")  # ∂_y ψ
        # Lz ψ = −i(x ∂_y ψ − y ∂_x ψ)
        return -1j * (self.X.to(torch.complex128) * dpsi_y
                      - self.Y.to(torch.complex128) * dpsi_x)

    @torch.no_grad()
    def diagnostics(self, psi: torch.Tensor) -> Tuple[float, ...]:
        """
        Compute conserved quantities and their current values.

        Returns
        -------
        Etot, Ekin, Eint, Etrap, N, Lz, rho_max

        Energy decomposition  [C7]
        --------------------------
        E_kin  = ½ ∫ |∇ψ|² dA          (kinetic energy, spectral)
        E_int  = (g/2) ∫ |ψ|⁴ dA       (interaction, 2D mean-field [C7])
        E_trap = ∫ V_trap(r) |ψ|² dA   (trap potential)

        Rotating-frame Hamiltonian  [C4]
        --------------------------------
        When Omega != 0, the conserved quantity in the rotating frame is
            H_rot = E_kin + E_int + E_trap − Omega · Lz
        This function returns H_rot as Etot when Omega != 0, so that the
        conservation error tracker monitors the correct conserved quantity.
        The raw lab-frame energy E_lab = E_kin + E_int + E_trap is NOT
        conserved in the rotating frame and is NOT what is tracked.
        """
        cfg  = self.cfg
        rho  = torch.abs(psi) ** 2
        N    = torch.sum(rho).item() * cfg.dx * cfg.dy
        rho_max = torch.max(rho).item()

        psi_k = torch.fft.fft2(psi, norm="ortho")
        dpx   = torch.fft.ifft2(self._iKX * psi_k, norm="ortho")
        dpy   = torch.fft.ifft2(self._iKY * psi_k, norm="ortho")

        Ekin  = (0.5 * torch.sum(torch.abs(dpx) ** 2 + torch.abs(dpy) ** 2).item()
                 * cfg.dx * cfg.dy)
        Eint  = (0.5 * cfg.g * torch.sum(rho ** 2).item()
                 * cfg.dx * cfg.dy)                    # [C7] valid 2D mean-field
        Etrap = (torch.sum(self.V * rho).item()
                 * cfg.dx * cfg.dy)

        # Angular momentum Lz = ∫ ψ* Lz_hat ψ dA  (spectral, [C4])
        Lz_psi = -1j * (self.X.to(torch.complex128) * dpy
                        - self.Y.to(torch.complex128) * dpx)
        Lz = (torch.sum(torch.conj(psi) * Lz_psi).real.item()
              * cfg.dx * cfg.dy)
        del dpx, dpy, psi_k, Lz_psi

        # [C4] Rotating-frame Hamiltonian is the conserved quantity
        if self._has_rotation:
            Etot = Ekin + Eint + Etrap - cfg.Omega * Lz
        else:
            Etot = Ekin + Eint + Etrap

        return Etot, Ekin, Eint, Etrap, N, Lz, rho_max

    # ── [C3] + [C4] Single time step (BAB Strang splitting) ──────────────────

    @torch.no_grad()
    def step(self, psi: torch.Tensor) -> torch.Tensor:
        """
        Advance ψ by one time step dt using BAB Strang splitting.

        BAB = kinetic half-step (B/2) → nonlinear full-step (A) → kinetic half-step (B/2).

        [C3 FIX] The density ρ for the nonlinear phase is computed AFTER
        the first kinetic half-step (at the step midpoint), which is the
        correct prescription for the BAB form.  The original code computed
        ρ before the first kinetic half-step and passed it in as an argument
        (start-of-step density), which corresponds to a different operator
        ordering with a different error constant (though still second-order).

        [C4 FIX] The rotating-frame term −Omega·Lz is applied as an exact
        angular rotation exp(−i Omega dt Lz) via bilinear interpolation
        on the rotated coordinate grid.  This correctly implements the
        unitary rotation operator rather than the previous approximation
        which incorrectly treated Lz as a pointwise multiplication operator.

        Parameters
        ----------
        psi : complex wave-function at the current time step

        Returns
        -------
        psi : complex wave-function at time t + dt
        """
        cfg = self.cfg

        # ── Kinetic half-step (B/2) ───────────────────────────────────────────
        psi_k = torch.fft.fft2(psi, norm="ortho")
        psi_k.mul_(self.prop_half)
        psi   = torch.fft.ifft2(psi_k, norm="ortho")
        del psi_k

        # ── [C3] Density at step midpoint ─────────────────────────────────────
        rho_mid = torch.abs(psi) ** 2

        # ── Nonlinear + trap phase (full step, A) ─────────────────────────────
        nl_potential = cfg.g * rho_mid + self.V   # real, shape (Nx, Ny)
        psi.mul_(torch.exp((-1j) * cfg.dt * nl_potential.to(torch.complex128)))

        # ── [C4] Rotating-frame rotation (exact unitary operator) ────────────
        if self._has_rotation:
            # exp(−i Omega dt Lz) rotates ψ by angle Omega*dt in the x-y plane.
            # This is the EXACT implementation of the unitary rotation operator,
            # as opposed to the incorrect pointwise phase approximation.
            psi = self._apply_Lz_rotation(psi, cfg.Omega * cfg.dt)

        # ── Kinetic half-step (B/2) ───────────────────────────────────────────
        psi_k = torch.fft.fft2(psi, norm="ortho")
        psi_k.mul_(self.prop_half)
        psi   = torch.fft.ifft2(psi_k, norm="ortho")
        del psi_k

        return psi

    # ── Radial profile ────────────────────────────────────────────────────────

    def radial_profile(self, rho_np: np.ndarray,
                       n_bins: Optional[int] = None) -> Tuple[np.ndarray, np.ndarray]:
        n_bins = n_bins or RADIAL_PROFILE_BINS
        r_bins = np.linspace(0, self.cfg.Lx, n_bins + 1)
        rho_r, _ = np.histogram(self.R_flat, bins=r_bins, weights=rho_np.ravel())
        cnt,   _ = np.histogram(self.R_flat, bins=r_bins)
        with np.errstate(divide='ignore', invalid='ignore'):
            rho_r = np.divide(rho_r, cnt, where=cnt > 0)
        return 0.5 * (r_bins[:-1] + r_bins[1:]), rho_r

    # ── Main run loop ─────────────────────────────────────────────────────────

    def run(self, psi0: torch.Tensor, label: str = "sim",
            save_fields: bool = True, n_save: int = NSAVE_DEFAULT,
            phi_nl_max: float = PHI_NL_MAX_PROD) -> dict:
        """
        Integrate the GPE from t=0 to t=T.

        Parameters
        ----------
        psi0        : initial wave-function
        label       : identifier string for output files
        save_fields : whether to save snapshots to disk
        n_save      : approximate number of snapshots
        phi_nl_max  : nonlinear-phase threshold for stability warning [C5]

        Returns
        -------
        Dictionary of time series, final state, and metadata.
        """
        cfg   = self.cfg
        steps = int(cfg.T / cfg.dt)
        interval = max(1, steps // n_save)

        psi  = psi0.clone()
        snap = SnapshotManager(OUTPUT_DIR, label) if save_fields else None

        E0, _, _, _, N0, Lz0, rho0_max = self.diagnostics(psi)
        stab = cfg.validate(N0, phi_nl_max=phi_nl_max)

        # [C5] Nonlinear-phase criterion
        if not stab['nl_phase_satisfied']:
            print(f"  ⚠️  [{label}] Nonlinear phase per step = "
                  f"{stab['nl_phase_per_step']:.3f} rad  exceeds threshold "
                  f"{stab['nl_phase_threshold']:.3f} rad.  "
                  f"Consider reducing dt.")

        # [C2] Report N_cr validity
        ncr_flag = ("" if stab['N_cr_trap_valid']
                    else f"  ⚠️  N_cr trap correction EXTRAPOLATED "
                         f"(V/|g|={stab['V_over_g']:.2f} > {NCR_CORRECTION_MAX_RATIO})")
        print(f"\n[{label}]  N0={N0:.4f} "
              f"| N/N_cr(free)={stab['N_over_Ncr_free']:.4f} "
              f"| N/N_cr(trap)={stab['N_over_Ncr_trap']:.4f} "
              f"| {'SAFE' if stab['collapse_safe'] else 'COLLAPSE RISK'}"
              f"{ncr_flag}")

        # [C10] Boundary check on initial condition
        self.check_boundary(psi, label=label)

        # [C6] Collapse thresholds, all relative to initial peak density
        collapse_abs_threshold = COLLAPSE_ABS_MULT * rho0_max

        data = dict(
            t=[], E=[], E_kin=[], E_int=[], E_trap=[],
            N=[], Lz=[], rho_max=[],
            E_err=[], N_err=[], Lz_err=[],
            max_E_err=0.0, max_N_err=0.0, max_Lz_err=0.0,
            E0=E0, N0=N0, Lz0=Lz0,
            stab=stab, collapsed=False, label=label,
            rho_max_prev=rho0_max, t_prev=None, rate_counter=0,
            rho0_max=rho0_max,
        )

        pbar = tqdm(range(steps), desc=label, colour='blue')
        for i in pbar:

            # [C3] No longer pre-compute rho here — done inside step()
            psi = self.step(psi)

            if i % interval == 0:
                E, Ek, Ei, Et, N, Lz, rho_max = self.diagnostics(psi)
                t_cur = i * cfg.dt

                data['t'].append(t_cur)
                data['E'].append(E);          data['E_kin'].append(Ek)
                data['E_int'].append(Ei);     data['E_trap'].append(Et)
                data['N'].append(N);          data['Lz'].append(Lz)
                data['rho_max'].append(rho_max)
                data['E_err'].append(abs(E  - E0)  / (abs(E0)  + 1e-30))
                data['N_err'].append(abs(N  - N0)  / (abs(N0)  + 1e-30))
                data['Lz_err'].append(abs(Lz - Lz0))

                if save_fields:
                    snap.save(psi)

                # ── Collapse detection [C6] ────────────────────────────────
                collapse   = False
                rho_ratio  = rho_max / rho0_max
                if rho_ratio > COLLAPSE_RHO_FACTOR:
                    collapse = True
                if rho_max > collapse_abs_threshold:
                    collapse = True
                if data['t_prev'] is not None:
                    dt_snap     = t_cur - data['t_prev']
                    # [C6 FIX] growth_rate has units 1/time, threshold is 2.0/time_unit
                    # Report dt_snap for reproducibility of collapse sensitivity.
                    growth_rate = ((rho_max - data['rho_max_prev'])
                                   / dt_snap / rho0_max)
                    if growth_rate > COLLAPSE_RATE_THRESH:
                        data['rate_counter'] += 1
                    else:
                        data['rate_counter'] = 0
                    if data['rate_counter'] >= COLLAPSE_RATE_WINDOW:
                        collapse = True
                        if 'dt_snap_at_collapse' not in data:
                            data['dt_snap_at_collapse'] = dt_snap  # [C6]

                data['rho_max_prev'] = rho_max
                data['t_prev']       = t_cur

                if collapse:
                    data['collapsed'] = True
                    dt_snap_info = data.get('dt_snap_at_collapse', interval * cfg.dt)
                    print(f"  ⚠️  COLLAPSE at t={t_cur:.2f}  "
                          f"rho_max={rho_max:.4f}  ratio={rho_ratio:.2f}  "
                          f"abs_thresh={collapse_abs_threshold:.4f}  "
                          f"rate_dt_snap={dt_snap_info:.3e}")  # [C6]
                    break

                pbar.set_postfix(E=f"{data['E_err'][-1]:.1e}",
                                 N=f"{data['N_err'][-1]:.1e}")
                if i % CACHE_CLEAN_INTERVAL == 0 and DEVICE.type == 'cuda':
                    torch.cuda.empty_cache()

        # Finalise
        if save_fields:
            snap.save(psi)
            data['snap_files'] = snap.saved_files
        else:
            data['snap_files'] = []
        pbar.close()

        for k in ['t', 'E', 'E_kin', 'E_int', 'E_trap',
                  'N', 'Lz', 'rho_max', 'E_err', 'N_err', 'Lz_err']:
            data[k] = np.array(data[k])

        data['max_E_err']  = data['E_err'].max()  if len(data['E_err'])  else 0.0
        data['max_N_err']  = data['N_err'].max()  if len(data['N_err'])  else 0.0
        data['max_Lz_err'] = data['Lz_err'].max() if len(data['Lz_err']) else 0.0
        data['rho_ratio']  = (data['rho_max'][-1] / data['rho_max'][0]
                              if len(data['rho_max']) else 1.0)
        data['psi_final']  = psi.detach().cpu().numpy()
        data['Lz_abs_min'] = np.min(np.abs(data['Lz'])) if len(data['Lz']) else 0.0
        data['Lz_abs_max'] = np.max(np.abs(data['Lz'])) if len(data['Lz']) else 0.0

        print(f"  Max ΔE/E0={data['max_E_err']:.2e}  "
              f"ΔN/N0={data['max_N_err']:.2e}  "
              f"|ΔLz|={data['max_Lz_err']:.2e}  "
              f"ρ_ratio={data['rho_ratio']:.3f}  "
              f"|Lz|∈[{data['Lz_abs_min']:.2e},{data['Lz_abs_max']:.2e}]")
        return data


# =============================================================================
# ── Convergence test [C8] ─────────────────────────────────────────────────────
# =============================================================================

def _align_multipeak(psi_test: np.ndarray,
                     psi_ref:  np.ndarray) -> np.ndarray:
    """
    Global-phase alignment of psi_test to psi_ref.

    The global phase is removed by rotating psi_test by the argument of
    the inner product ⟨ψ_ref, ψ_test⟩.  This is sufficient for convergence
    order estimation when the peaks maintain relative phase coherence
    (i.e. the inter-peak phase differences are the same in both test and
    reference solutions, as expected for well-converged necklace states).

    Note  [C8 FIX]
    --------------
    The original code contained a docstring claiming per-peak mode-
    decomposition alignment, but the implementation performed only
    global phase alignment.  This function now correctly documents
    what it computes: a single global phase rotation.  Per-peak
    alignment would require identifying peak positions and rotating
    each peak's local phase independently, which is only necessary
    when comparing solutions at very different resolutions where
    inter-peak phase drift is significant.  For the convergence
    parameter ranges used here (dt and Nx within a factor of 10 of
    the reference), global alignment is appropriate.
    """
    prod  = np.vdot(psi_ref, psi_test)
    phase = np.angle(prod)
    return psi_test * np.exp(-1j * phase)


def run_convergence_test() -> dict:
    print("\n" + "=" * 60)
    print("[Convergence Test] dt sweep + Nx sweep")
    print("=" * 60)
    base_cfg = dict(Lx=25.0, Ly=25.0, T=CONV_T,
                    g=G_SINGLE, V_trap=V_TRAP_SINGLE)
    dt_results = []

    # Reference solution at finest dt
    print("\n  [dt sweep] Nx=512, computing reference at finest dt …")
    dt_ref  = CONV_DT_LIST[-1]
    cfg_ref = SimConfig(Nx=512, Ny=512, dt=dt_ref, **base_cfg)
    sol_ref = GPESolver(cfg_ref)
    psi0_r  = sol_ref.necklace_initial()
    dat_ref = sol_ref.run(psi0_r, f'conv_ref_dt{dt_ref:.0e}',
                          save_fields=False, n_save=NSAVE_CONVERGENCE,
                          phi_nl_max=PHI_NL_MAX_SCAN)
    psi_ref  = dat_ref['psi_final'].copy()
    ref_norm = np.linalg.norm(psi_ref)
    del sol_ref, psi0_r, dat_ref
    if DEVICE.type == 'cuda':
        torch.cuda.empty_cache(); torch.cuda.synchronize()

    for dt in CONV_DT_LIST[:-1]:
        cfg  = SimConfig(Nx=512, Ny=512, dt=dt, **base_cfg)
        sol  = GPESolver(cfg)
        psi0 = sol.necklace_initial()
        dat  = sol.run(psi0, f'conv_dt{dt:.0e}',
                       save_fields=False, n_save=NSAVE_CONVERGENCE,
                       phi_nl_max=PHI_NL_MAX_SCAN)
        psi_np      = dat['psi_final'].copy()
        # [C8] Global phase alignment (see _align_multipeak docstring)
        psi_aligned = _align_multipeak(psi_np, psi_ref)
        sol_err     = np.linalg.norm(psi_aligned - psi_ref) / (ref_norm + 1e-30)

        print(f"  dt={dt:.0e}  E_err={dat['max_E_err']:.2e}  sol_err={sol_err:.2e}")
        dt_results.append({
            'dt':    float(dt),
            'E_err': float(dat['max_E_err']),
            'N_err': float(dat['max_N_err']),
            'sol_err': float(sol_err),
        })
        del sol, psi0, dat, psi_np
        if DEVICE.type == 'cuda':
            torch.cuda.empty_cache()

    # Nx sweep at fixed fine dt
    nx_results = []
    print("\n  [Nx sweep] fixed dt=1e-5 …")
    fixed_dt = 1e-5
    for nx in CONV_NX_LIST:
        cfg  = SimConfig(Nx=nx, Ny=nx, dt=fixed_dt, **base_cfg)
        sol  = GPESolver(cfg)
        psi  = sol.necklace_initial()
        dat  = sol.run(psi, f'conv_nx{nx}',
                       save_fields=False, n_save=NSAVE_CONVERGENCE,
                       phi_nl_max=PHI_NL_MAX_SCAN)
        nx_results.append({
            'Nx':    nx,
            'dx':    cfg.dx,
            'dt':    fixed_dt,
            'E_err': float(dat['max_E_err']),
            'N_err': float(dat['max_N_err']),
        })
        del sol, psi, dat
        if DEVICE.type == 'cuda':
            torch.cuda.empty_cache()

    res = {'dt_results': dt_results, 'nx_results': nx_results}
    with open(f'{OUTPUT_DIR}/convergence.json', 'w') as f:
        json.dump(res, f, indent=2)
    print("[Convergence Test] done.")
    return res


def fig_convergence(conv_res: dict):
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))
    plt.subplots_adjust(wspace=0.30)

    dts      = np.array([r['dt']      for r in conv_res['dt_results']])
    sol_errs = np.array([r['sol_err'] for r in conv_res['dt_results']])
    idx_sort = np.argsort(dts)[::-1]
    dts      = dts[idx_sort];  sol_errs = sol_errs[idx_sort]

    ax1.loglog(dts, sol_errs, '^-', color=C['teal'], lw=2.0, ms=8,
               label='Solution error (global phase-aligned) [C8]')

    mask = sol_errs > 1e-14
    if np.sum(mask) >= 2:
        slope, intercept = np.polyfit(np.log10(dts[mask]),
                                      np.log10(sol_errs[mask]), 1)
        dt_fit = np.geomspace(dts[mask].min(), dts[mask].max(), 80)
        ax1.loglog(dt_fit, 10 ** intercept * dt_fit ** slope, '--',
                   color=C['grey'], lw=1.5,
                   label=fr'Fit: $\mathcal{{O}}(\Delta t^{{{slope:.2f}}})$')
        ref2 = sol_errs[0] * (dts / dts[0]) ** 2
        ax1.loglog(dts, ref2, ':', color=C['red'], lw=1.5,
                   label=r'$\mathcal{O}(\Delta t^2)$ reference')

    ax1.set_xlabel(r'Time step $\Delta t$')
    ax1.set_ylabel('Relative solution error')
    ax1.set_title('Temporal convergence (BAB Strang splitting, 2nd order)',
                  fontsize=11)
    ax1.legend(fontsize=9, loc='upper left')
    style_ax(ax1);  panel_label(ax1, 'a')

    dxs  = np.array([r['dx']    for r in conv_res['nx_results']])
    e_nx = np.array([r['E_err'] for r in conv_res['nx_results']])
    idx2 = np.argsort(dxs)[::-1]
    dxs  = dxs[idx2];  e_nx = e_nx[idx2]

    ax2.loglog(dxs, e_nx, 's-', color=C['red'], lw=2.0, ms=8,
               label='Energy error')
    ax2.set_xlabel(r'Grid spacing $\Delta x$')
    ax2.set_ylabel(r'Max rel. energy error $|\Delta E / E_0|$')
    ax2.set_title('Spatial convergence (pseudo-spectral)', fontsize=11)
    ax2.legend(fontsize=9, loc='upper left')
    style_ax(ax2);  panel_label(ax2, 'b')

    fig.savefig(f'{OUTPUT_DIR}/Fig5_Convergence.pdf',
                bbox_inches='tight', dpi=600)
    plt.close()
    print("[Fig5] saved.")


