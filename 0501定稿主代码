def _count_peaks_2d(rho: np.ndarray) -> int:
    rho_s   = ndimage.gaussian_filter(rho, sigma=GAUSSIAN_SMOOTH_SIGMA)
    maxima  = np.zeros_like(rho_s, dtype=bool)
    maxima[1:-1, 1:-1] = (
        (rho_s[1:-1, 1:-1] > rho_s[:-2,  1:-1]) &
        (rho_s[1:-1, 1:-1] > rho_s[2:,   1:-1]) &
        (rho_s[1:-1, 1:-1] > rho_s[1:-1, :-2 ]) &
        (rho_s[1:-1, 1:-1] > rho_s[1:-1, 2:  ])
    )
    threshold = PEAK_THRESH_REL * rho_s.max()
    peak_mask = maxima & (rho_s > threshold)
    y, x   = np.where(peak_mask)
    peaks  = list(zip(y, x))
    keep   = []
    for p in peaks:
        if all(np.hypot(p[0]-q[0], p[1]-q[1]) > PEAK_MIN_DIST for q in keep):
            keep.append(p)
    return len(keep)


def _radial_correlation(rho_final: np.ndarray, rho_init: np.ndarray,
                        R_flat: np.ndarray, Lx: float) -> float:
    r_bins = np.linspace(0, Lx, RADIAL_CORR_BINS + 1)
    def radial_mean(rho):
        flat      = rho.ravel()
        hist, _   = np.histogram(R_flat, bins=r_bins, weights=flat)
        cnt,  _   = np.histogram(R_flat, bins=r_bins)
        with np.errstate(divide='ignore', invalid='ignore'):
            return np.where(cnt > 0, hist / cnt, 0.0)
    r_fin = radial_mean(rho_final);  r_ini = radial_mean(rho_init)
    denom = np.std(r_fin) * np.std(r_ini)
    if denom < 1e-20:
        return 0.0
    return float(np.corrcoef(r_fin, r_ini)[0, 1])


def classify_collision(dat, rho_init_np: np.ndarray,
                       R_flat: np.ndarray, Lx: float,
                       snap_files: list) -> dict:
    z_final   = np.load(snap_files[-1])
    rho_final = np.abs(z_final) ** 2
    rho_ratio = float(dat['rho_ratio'])
    n_peaks   = _count_peaks_2d(rho_final)
    r_corr    = _radial_correlation(rho_final, rho_init_np, R_flat, Lx)

    base = {'rho_ratio': rho_ratio, 'n_peaks': n_peaks, 'radial_corr': r_corr}

    if dat['collapsed']:
        return dict(type='collapse', **base)
    if n_peaks > MAX_REASONABLE_PEAKS:
        return dict(type='numerical_fragmentation', **base)
    if QE_MIN_PEAKS <= n_peaks <= QE_MAX_PEAKS and r_corr > QE_MIN_CORR:
        return dict(type='quasi-elastic', **base)
    if n_peaks <= FUSION_MAX_PEAKS:
        return dict(type='fusion', **base)
    if n_peaks >= FRAG_MIN_PEAKS or r_corr < FRAG_MAX_CORR:
        return dict(type='fragmentation', **base)
    return dict(type='transition', **base)


def run_collision_scan() -> list:
    print("\n" + "=" * 60)
    print(f"[Collision Scan] k0 sweep: {COLL_V_LIST}")
    print("[C1] k0 is the radial wave-vector (1/length); group velocity = k0 (ℏ=m=1).")
    print("[C1] Phase applied locally at each peak (not from global grid origin).")
    print("=" * 60)
    print("→ 使用自适应时间步长和分辨率策略（高速区加强数值控制）")

    results = []
    for k0 in COLL_V_LIST:
        label = f'coll_k0_{k0:.2f}'

        # ====================== 核心修改：自适应参数 ======================
        abs_k0 = abs(float(k0))
        
        # 根据碰撞速度动态调整 dt 和 Nx
        if abs_k0 >= 2.5:
            dt_used = 1e-5      # 极高速：最严格
            nx_used = 1024
        elif abs_k0 >= 1.5:
            dt_used = 2e-5      # 高速区
            nx_used = 768
        elif abs_k0 >= 0.8:
            dt_used = 3e-5
            nx_used = 640
        else:
            dt_used = 5e-5      # 低速区
            nx_used = NX_COLL   # 默认 512

        # 非线性相位安全检查（双环重叠时密度约2倍）
        rho_est = 2 * A_PEAK ** 2
        nl_phase_est = abs(G_COLL) * rho_est * dt_used

        if nl_phase_est > 0.08:
            print(f"  ⚠️  [High nonlinearity / High velocity] k0={k0:.2f}, "
                  f"dt={dt_used:.1e}, phi_NL/step ≈ {nl_phase_est:.3f} rad")

        # ====================== 配置与运行 ======================
        cfg = SimConfig(
            Nx=nx_used,
            Ny=nx_used,
            Lx=LX_COLL,
            Ly=LY_COLL,
            dt=dt_used,
            T=COLL_T,
            g=G_COLL,
            V_trap=V_TRAP_COLL,
            w_peak=W_PEAK
        )

        sol = GPESolver(cfg)
        psi = sol.two_ring_collision(R1=R1_COLL, R2=R2_COLL, k0=k0)
        
        rho_init_np = (torch.abs(psi) ** 2).detach().cpu().numpy()

        dat = sol.run(psi, label, 
                      save_fields=True, 
                      n_save=NSAVE_COLLISION,
                      phi_nl_max=PHI_NL_MAX_SCAN)

        cls = classify_collision(dat, rho_init_np, sol.R_flat,
                                 LX_COLL, dat['snap_files'])

        # ====================== 保存结果 ======================
        results.append({
            'k0':            float(k0),
            'v_phys':        float(k0),
            'type':          cls['type'],
            'rho_ratio':     cls['rho_ratio'],
            'n_peaks':       cls['n_peaks'],
            'radial_corr':   cls['radial_corr'],
            'max_E_err':     float(dat['max_E_err']),
            'collapsed':     bool(dat['collapsed']),
            'snap_files':    dat['snap_files'],
            't':             dat['t'].tolist(),
            'rho_max':       dat['rho_max'].tolist(),
            'Lz_abs_min':    dat['Lz_abs_min'],
            'Lz_abs_max':    dat['Lz_abs_max'],
            # 新增字段：用于后续分析和回复审稿人
            'dt_used':       float(dt_used),
            'Nx_used':       int(nx_used),
            'nl_phase_est':  float(nl_phase_est)
        })

        print(f"  k0={k0:5.2f} | Nx={nx_used:4d} | dt={dt_used:.1e} → "
              f"[{cls['type']:20s}]  ρ_ratio={cls['rho_ratio']:.3f}  "
              f"n_peaks={cls['n_peaks']:3d}  r_corr={cls['radial_corr']:.3f}")

        del sol, psi
        if DEVICE.type == 'cuda':
            torch.cuda.empty_cache()

    with open(f'{OUTPUT_DIR}/collision_scan.json', 'w') as f:
        json.dump(results, f, indent=2)

    print(f"\n[Collision Scan] 完成！共 {len(COLL_V_LIST)} 个 k0 点，已使用自适应 dt 与 Nx 策略。")
    return results


