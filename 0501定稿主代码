def run_2d_stability_scan() -> list:
    print("\n" + "=" * 60)
    print(f"[2D Stability Scan] {len(SCAN2D_G)}×{len(SCAN2D_V)} grid")
    print("=" * 60)
    print("→ 使用自适应时间步长策略以保证强非线性区数值可靠性")
    
    results = []
    total = len(SCAN2D_G) * len(SCAN2D_V)
    count = 0

    for g in SCAN2D_G:
        row = []
        for vt in SCAN2D_V:
            count += 1
            label = f'2d_g{g:.3f}_v{vt:.4f}'

            # ====================== 关键修改部分 ======================
            # 根据 |g| 强度动态选择 dt（强吸引时必须用更小步长）
            abs_g = abs(float(g))
            if abs_g > 2.0:
                dt_used = 1e-5          # 极强吸引区
            elif abs_g > 1.0:
                dt_used = 2e-5          # 强吸引区
            elif abs_g > 0.5:
                dt_used = 3e-5
            else:
                dt_used = 5e-5          # 弱吸引区

            # 可选：强吸引时适当增加网格分辨率
            nx_used = 768 if abs_g > 1.5 else 512

            cfg = SimConfig(
                Nx=nx_used, 
                Ny=nx_used, 
                Lx=25.0, 
                Ly=25.0,
                dt=dt_used, 
                T=SCAN2D_T,
                g=float(g), 
                V_trap=float(vt)
            )

            # 非线性相位安全检查
            rho_est = A_PEAK ** 2
            nl_phase_est = abs_g * rho_est * dt_used
            if nl_phase_est > 0.08:
                print(f"  ⚠️  [Strong nonlinearity] g={g:.3f}, dt={dt_used:.1e}, "
                      f"phi_NL/step ≈ {nl_phase_est:.3f} rad (>0.08)")

            # ====================== 运行模拟 ======================
            sol = GPESolver(cfg)
            psi = sol.necklace_initial()
            
            dat = sol.run(psi, label, 
                          save_fields=False,
                          n_save=NSAVE_SCAN2D,
                          phi_nl_max=PHI_NL_MAX_SCAN)

            # [C2] Flag whether N_cr correction is in valid regime
            ncr_valid = cfg.N_cr_correction_valid

            row.append({
                'g':                    float(g),
                'V_trap':               float(vt),
                'V_over_g':             float(vt / abs(g)),
                'N_cr_trap_valid':      bool(ncr_valid),
                'collapsed':            bool(dat['collapsed']),
                'rho_ratio':            float(dat['rho_ratio']),
                'E_err':                float(dat['max_E_err']),
                'N_over_Ncr_free':      float(dat['N0'] / cfg.N_cr_free),
                'N_over_Ncr_trap':      float(dat['N0'] / cfg.N_cr_trap),
                'dt_used':              float(dt_used),          # 新增：记录实际dt
                'Nx_used':              int(nx_used),            # 新增：记录实际分辨率
                'nl_phase_est':         float(nl_phase_est)      # 新增：估计相位
            })

            status = 'COLLAPSED' if dat['collapsed'] else 'stable'
            validity = '' if ncr_valid else ' [Ncr EXTRAPOLATED]'
            
            print(f"  [{count:3d}/{total}] g={g:.3f}, V={vt:.4f} | dt={dt_used:.1e} "
                  f"→ {status}  ρ_ratio={dat['rho_ratio']:.3f}  "
                  f"N/Ncr(trap)={row[-1]['N_over_Ncr_trap']:.3f}{validity}")

            del sol, psi
            if DEVICE.type == 'cuda':
                torch.cuda.empty_cache()

        results.append(row)

    with open(f'{OUTPUT_DIR}/scan2d.json', 'w') as f:
        json.dump(results, f, indent=2)

    print(f"\n[2D Scan] 完成！共 {total} 个参数点，已使用自适应 dt 策略。")
    return results


