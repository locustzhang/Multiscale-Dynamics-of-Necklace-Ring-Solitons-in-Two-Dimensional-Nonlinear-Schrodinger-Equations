@dataclass
class SimConfig:
    """
    Simulation configuration for the 2-D GPE.

    Unit system
    -----------
    Length  : ξ  (healing length of the reference state)
    Time    : ℏ / (m c²)  with c = Bogoliubov sound speed
    Energy  : m c²
    In practice ℏ = m = 1 and lengths are set by the domain.

    Wave-function normalisation
    ---------------------------
    ψ is NOT normalised to unit L² norm.  The particle number is
        N = ∫ |ψ|² dA
    and is set by the initial amplitude A_peak and width w_peak.
    The coupling g is a dimensionless 2D coupling constant:
        g_2D = g_3D / (√(2π) a_z)   [tight-confinement limit]
    Comparison with 3D experiments must account for this factor.  [C7]

    Grid symmetry  [C9]
    -------------------
    The x- and y-grids are constructed via linspace to guarantee exact
    symmetry about 0 for any Nx.  This ensures the harmonic trap minimum
    V_trap(r=0) = 0 is exactly represented on the grid.

    Parameters
    ----------
    Nx, Ny   : grid points along x, y
    Lx, Ly   : half-domain size (domain is [−L, L])
    dt       : time step; must satisfy |g|·ρ_max·dt < PHI_NL_MAX
    T        : total integration time
    N_peaks  : number of bright solitons on the ring
    R_ring   : ring radius
    A_peak   : peak amplitude of each Gaussian blob
    w_peak   : Gaussian width (1/e radius)
    g        : coupling constant (< 0 attractive)
    V_trap   : harmonic trap coefficient (0 = free space)
    Omega    : angular velocity of rotating frame (rad / t_unit)
    seed     : RNG seed for reproducibility
    """
    Nx:        int   = 512
    Ny:        int   = 512
    Lx:        float = 25.0
    Ly:        float = 25.0
    dt:        float = DT_DEFAULT
    T:         float = 6.0
    N_peaks:   int   = N_PEAKS
    R_ring:    float = R_RING
    A_peak:    float = A_PEAK
    w_peak:    float = W_PEAK
    g:         float = -0.08
    V_trap:    float = 0.001
    Omega:     float = OMEGA_ROT
    seed:      int   = SEED
    dtype_real: torch.dtype = torch.float64
    dtype_cplx: torch.dtype = torch.complex128

    def __post_init__(self):
        # [C9] Use linspace for exact symmetry: grid spans (−Lx, Lx) exclusive
        # of the repeated endpoint, symmetric about 0 for any Nx.
        self.dx = 2 * self.Lx / self.Nx
        self.dy = 2 * self.Ly / self.Ny
        # linspace(−Lx + dx/2, Lx − dx/2, Nx) centres cells symmetrically
        half_dx = self.dx / 2.0
        half_dy = self.dy / 2.0
        self.x = torch.linspace(
            -self.Lx + half_dx, self.Lx - half_dx, self.Nx,
            device=DEVICE, dtype=self.dtype_real)
        self.y = torch.linspace(
            -self.Ly + half_dy, self.Ly - half_dy, self.Ny,
            device=DEVICE, dtype=self.dtype_real)

    # ── [C2] Trap-corrected critical norm ──────────────────────────────────────
    @property
    def N_cr_free(self) -> float:
        """
        Free-space (V_trap = 0) Townes-soliton critical norm.

        For the GPE written as i∂_t ψ = −½∇²ψ + g|ψ|²ψ (g < 0),
        the critical norm is N_cr = ‖R‖²_L² where R is the Townes
        profile, giving:
            N_cr(0) = 11.70 / (2|g|) = 5.85 / |g|

        Reference: Bergé (1998), Phys. Rep. 303, 259, Table 1;
                   Sulem & Sulem (1999), Eq. (3.37).
        Convention check: this value is correct for the Hamiltonian
            H = ½|∇ψ|² + (g/2)|ψ|⁴
        which matches the code exactly.
        """
        return 5.85 / abs(self.g)

    @property
    def N_cr_correction_valid(self) -> bool:
        """
        True if V_trap / |g| ≤ NCR_CORRECTION_MAX_RATIO,
        i.e. the linear variational correction is in its valid regime.
        """
        return (self.V_trap / abs(self.g)) <= NCR_CORRECTION_MAX_RATIO

    @property
    def N_cr_trap(self) -> float:
        """
        Trap-corrected critical norm (Gaussian variational ansatz).

        Valid in the weak-confinement limit V_trap / |g| ≤ 0.5.
        The correction factor from the Gaussian width minimisation is:
            N_cr(V) = N_cr(0) · [1 + ALPHA_NCR · V_trap / |g|]
        with ALPHA_NCR = 4π.

        For parameters outside the valid range, this formula can
        overestimate N_cr significantly (e.g. V/|g| = 2 gives a 25×
        correction which is unphysical).  Use N_cr_correction_valid to
        check before trusting this value.  [C2]
        """
        correction = 1.0 + ALPHA_NCR * self.V_trap / abs(self.g)
        return self.N_cr_free * correction

    def validate(self, N_total: float, phi_nl_max: float = PHI_NL_MAX_PROD) -> dict:
        """
        Check physical and numerical self-consistency.

        Criteria
        --------
        [C5] Nonlinear phase per step: |g|·ρ_peak·dt < phi_nl_max
        [C2] Collapse safety uses trap-corrected N_cr with validity flag
        [C10] Boundary condition compatibility (checked separately in run)
        """
        rho_peak_est = self.A_peak ** 2
        nl_phase     = abs(self.g) * rho_peak_est * self.dt

        return {
            'nl_phase_per_step':          nl_phase,
            'nl_phase_satisfied':         nl_phase < phi_nl_max,
            'nl_phase_threshold':         phi_nl_max,
            'nyquist_wavenumber':         np.pi / self.dx,
            'peak_wavenumber_estimate':   2 * np.pi / self.w_peak,
            'spectral_resolved':          (np.pi / self.dx) > (2 * np.pi / self.w_peak),
            'N_total':                    N_total,
            'N_cr_free':                  self.N_cr_free,
            'N_cr_trap':                  self.N_cr_trap,
            'N_cr_trap_valid':            self.N_cr_correction_valid,  # [C2]
            'V_over_g':                   self.V_trap / abs(self.g),   # [C2]
            'N_over_Ncr_free':            N_total / self.N_cr_free,
            'N_over_Ncr_trap':            N_total / self.N_cr_trap,
            'collapse_safe':              N_total < self.N_cr_trap,
            'rotating_frame':             self.Omega != 0.0,
        }

    def print_config(self):
        valid_str = ("valid" if self.N_cr_correction_valid
                     else f"EXTRAPOLATED (V/|g|={self.V_trap/abs(self.g):.2f} > {NCR_CORRECTION_MAX_RATIO})")
        print(f"  Grid    : Nx={self.Nx}, Ny={self.Ny}, "
              f"L={self.Lx:.1f}, dx={self.dx:.4f}")
        print(f"  Soliton : N_peaks={self.N_peaks}, R={self.R_ring}, "
              f"A={self.A_peak}, w={self.w_peak}")
        print(f"  Physics : g={self.g}, V_trap={self.V_trap}, "
              f"Omega={self.Omega}")
        print(f"  Precision: float64 + complex128")
        print(f"  N_cr (free-space, lower bound)  = {self.N_cr_free:.4f}")
        print(f"  N_cr (trap-corrected, {valid_str}) = {self.N_cr_trap:.4f}  "
              f"[correction = {self.N_cr_trap/self.N_cr_free:.3f}×]")

