def main():
    print("=" * 70)
    print("Necklace Soliton Simulation — Journal-Ready (Physics-Corrected)")
    print(f"Device : {DEVICE}")
    print(f"Output : {OUTPUT_DIR}/")
    print()
    print("Physical corrections applied in this version:")
    print("  [C1]  k0 = radial wave-vector (1/length); phase applied locally")
    print("         at each peak, not from global grid origin.")
    print("  [C2]  N_cr trap correction valid only for V/|g| ≤ 0.5;")
    print("         extrapolated points flagged in all outputs and figures.")
    print("  [C3]  BAB Strang splitting: ρ at step midpoint (after first")
    print("         kinetic half-step), not at step start.")
    print("  [C4]  Rotating frame: exp(−iΩdt Lz) implemented as exact")
    print("         angular rotation via bilinear interpolation; conserved")
    print("         quantity is H_rot = E_kin+E_int+E_trap−Ω·Lz.")
    print("  [C5]  Nonlinear-phase criterion replaces inapplicable CFL.")
    print("  [C6]  Collapse threshold relative to rho0; dt_snap logged.")
    print("  [C7]  E_int = (g/2)∫|ψ|⁴dA, valid 2D mean-field form.")
    print("  [C8]  Convergence: global phase alignment (not per-peak),")
    print("         correctly documented.")
    print("  [C9]  Grid uses linspace for exact symmetry about origin.")
    print("  [C10] Boundary |ψ|/|ψ_max| check at initialisation.")
    print("=" * 70)

    # ── [1/8] Single ring ─────────────────────────────────────────────────────
    print("\n[1/8] Single ring simulation …")
    cfg_single = SimConfig(
        Nx=NX_SINGLE, Ny=NY_SINGLE, Lx=LX_SINGLE, Ly=LY_SINGLE,
        dt=DT_DEFAULT, T=T_SINGLE, g=G_SINGLE, V_trap=V_TRAP_SINGLE)
    cfg_single.print_config()
    sol_single  = GPESolver(cfg_single)
    psi_single  = sol_single.necklace_initial()
    data_single = sol_single.run(psi_single, label='SingleRing',
                                 save_fields=True, n_save=NSAVE_DEFAULT)

    # ── [2/8] Two-ring collision ──────────────────────────────────────────────
    print("\n[2/8] Two-ring collision simulation (k0=1.5) …")
    cfg_coll = SimConfig(
        Nx=NX_COLL, Ny=NY_COLL, Lx=LX_COLL, Ly=LY_COLL,
        dt=DT_DEFAULT, T=T_COLL, g=G_COLL, V_trap=V_TRAP_COLL)
    cfg_coll.print_config()
    sol_coll  = GPESolver(cfg_coll)
    psi_coll  = sol_coll.two_ring_collision(R1=R1_COLL, R2=R2_COLL, k0=1.5)
    data_coll = sol_coll.run(psi_coll, label='Collision',
                             save_fields=True, n_save=NSAVE_DEFAULT)

    # ── [3/8] 1-D g scan ─────────────────────────────────────────────────────
    scan1d_path = f'{OUTPUT_DIR}/scan1d.json'
    if os.path.exists(scan1d_path):
        print("\n[3/8] Loading cached 1D scan …")
        with open(scan1d_path) as f:
            scan1d = json.load(f)
    else:
        scan1d = run_1d_g_scan()

    # ── [4/8] Convergence ─────────────────────────────────────────────────────
    conv_path = f'{OUTPUT_DIR}/convergence.json'
    if os.path.exists(conv_path):
        print("\n[4/8] Loading cached convergence results …")
        with open(conv_path) as f:
            conv_res = json.load(f)
    else:
        conv_res = run_convergence_test()

    # ── [5/8] 2-D stability scan ──────────────────────────────────────────────
    scan2d_path = f'{OUTPUT_DIR}/scan2d.json'
    if os.path.exists(scan2d_path):
        print("\n[5/8] Removing stale 2D scan cache …")
        os.remove(scan2d_path)
    scan2d = run_2d_stability_scan()

    # ── [6/8] Collision scan ──────────────────────────────────────────────────
    coll_path = f'{OUTPUT_DIR}/collision_scan.json'
    if os.path.exists(coll_path):
        print("\n[6/8] Removing stale collision scan cache …")
        os.remove(coll_path)
        for snap_dir in glob.glob(os.path.join(OUTPUT_DIR, 'Snapshots_coll_*')):
            shutil.rmtree(snap_dir, ignore_errors=True)
    coll_res = run_collision_scan()

    # ── [7/8] Summary ─────────────────────────────────────────────────────────
    print("\n" + "=" * 80)
    print("PAPER KEY DATA SUMMARY")
    print("=" * 80)
    s = data_single
    print(f"Single ring  :  ΔH/H0={s['max_E_err']:.2e}  "
          f"ΔN/N0={s['max_N_err']:.2e}  |ΔLz|={s['max_Lz_err']:.2e}")
    c = data_coll
    print(f"Collision    :  ΔH/H0={c['max_E_err']:.2e}  "
          f"ΔN/N0={c['max_N_err']:.2e}  |ΔLz|={c['max_Lz_err']:.2e}")
    print(f"Collision Lz :  |Lz| ∈ [{c['Lz_abs_min']:.2e}, {c['Lz_abs_max']:.2e}]")

    type_counts: Dict[str, int] = {}
    for r in coll_res:
        type_counts[r['type']] = type_counts.get(r['type'], 0) + 1
    print("\nCollision type distribution:")
    for tp, cnt in sorted(type_counts.items()):
        print(f"  {tp}: {cnt}/{len(coll_res)} ({cnt/len(coll_res)*100:.1f}%)")

    n_coll = sum(1 for row in scan2d for e in row if e['collapsed'])
    n_tot  = sum(len(row) for row in scan2d)
    n_extrap = sum(1 for row in scan2d
                   for e in row if not e.get('N_cr_trap_valid', True))
    print(f"\n2D phase diagram — collapse fraction: "
          f"{n_coll}/{n_tot} = {n_coll/n_tot:.1%}  "
          f"| N_cr extrapolated points: {n_extrap}/{n_tot}")

    # ── [8/8] Figures ─────────────────────────────────────────────────────────
    print("\n[8/8] Generating journal figures …")
    fig1_single_ring(data_single, cfg_single)
    fig2_collision(data_coll, cfg_coll)
    fig3_conservation(data_single, data_coll)
    fig4_stability(data_single, scan1d, cfg_single)
    fig_convergence(conv_res)
    fig_2d_stability(scan2d)
    fig_collision_classification(coll_res)

    print("\n" + "=" * 70)
    print("All simulations and figures complete.")
    print(f"8 journal-ready PDF figures saved to: {OUTPUT_DIR}/")
    print("=" * 70)


if __name__ == '__main__':
    main()
