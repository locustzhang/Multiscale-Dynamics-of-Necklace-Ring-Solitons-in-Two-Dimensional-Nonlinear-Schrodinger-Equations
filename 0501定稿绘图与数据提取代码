def analyze_1d(scan1d):
    print("\n" + "="*92)
    print("📌 1. 1D 吸引相互作用强度扫描")
    print("="*92)
    if not scan1d:
        return {}
    print(f"共扫描 {len(scan1d)} 个 g 值\n")
    print(f"{'g':>8}  {'ρ_ratio':>8}  {'N/Ncr_free':>12}  {'N/Ncr_trap':>12}  {'E_err':>10}  {'Ncr有效':>8}")
    print("-" * 82)
    for it in scan1d:
        valid = "✓" if safe_get(it, 'N_cr_trap_valid', True) else "✗(外推)"
        print(f"{it['g']:8.3f}  {it['rho_ratio']:8.3f}  "
              f"{safe_get(it, 'N_over_Ncr_free'):12.3f}  "
              f"{safe_get(it, 'N_over_Ncr_trap'):12.3f}  "
              f"{safe_get(it, 'E_err', 0):10.2e}  {valid}")
    g_arr   = np.array([it['g'] for it in scan1d])
    rho     = np.array([it['rho_ratio'] for it in scan1d])
    n_free  = np.array([safe_get(it, 'N_over_Ncr_free') for it in scan1d])
    n_trap  = np.array([safe_get(it, 'N_over_Ncr_trap') for it in scan1d])
    print(f"\n统计总结：")
    print(f"  ρ_ratio     : 平均 = {rho.mean():.3f}  [范围 {rho.min():.3f} — {rho.max():.3f}]")
    print(f"  N/N_cr^trap : 平均 = {n_trap.mean():.2f}  最大 = {n_trap.max():.2f}")
    safe_idx = np.where(n_trap < 1.0)[0]
    if len(safe_idx) > 0:
        g_safe = g_arr[safe_idx[-1]]
        print(f"  ✅ 静态安全区：g ≳ {g_safe:.3f} 时 N/N_cr^trap < 1")
    else:
        print("  ⚠️  所有参数点均处于静态危险区 (N/N_cr^trap ≥ 1)")
    return {'rho_mean': float(rho.mean()), 'ncr_trap_max': float(n_trap.max())}

def analyze_convergence(conv):
    print("\n" + "="*92)
    print("📌 2. 数值收敛性测试")
    print("="*92)
    if not conv:
        return {}
    if dt_res := conv.get("dt_results"):
        print("\n时间步长 (dt) 收敛：")
        for r in sorted(dt_res, key=lambda x: x['dt']):
            print(f"  dt = {r['dt']:.0e}   sol_err = {r['sol_err']:.2e}   E_err = {safe_get(r,'E_err',0):.2e}")
    if nx_res := conv.get("nx_results"):
        print("\n空间分辨率 (Nx) 收敛：")
        for r in sorted(nx_res, key=lambda x: x['dx']):
            print(f"  Nx = {r['Nx']:4d}   dx = {r['dx']:.4f}   E_err = {r['E_err']:.2e}")
        if all(r['E_err'] < 1e-9 for r in nx_res):
            print("  ✅ 空间误差已达机器精度级别，谱方法收敛极好")
    return {}

def analyze_2d(scan2d):
    print("\n" + "="*92)
    print("📌 3. 2D 稳定性相图 (g–V_trap)")
    print("="*92)
    if not scan2d:
        return {}
    total = collapsed = valid_ncr = 0
    rho_list = []
    collapse_by_g = defaultdict(int)
    for row in scan2d:
        for p in row:
            total += 1
            if safe_get(p, 'collapsed'):
                collapsed += 1
                collapse_by_g[p['g']] += 1
            if safe_get(p, 'N_cr_trap_valid', True):
                valid_ncr += 1
            rho_list.append(p['rho_ratio'])
    rho_arr = np.array(rho_list)
    print(f"总参数点：{total} | 塌缩比例：{collapsed/total*100:.2f}%")
    print(f"ρ_ratio 平均 = {rho_arr.mean():.3f}，最大 = {rho_arr.max():.3f}")
    print(f"N_cr 修正有效比例：{valid_ncr/total*100:.1f}%")
    if 0 < collapsed < total:
        print("\n稳定性边界（每个 g 值下首次出现塌缩的 V_trap）：")
        for row in scan2d:
            g = row[0]['g']
            for p in row:
                if safe_get(p, 'collapsed'):
                    print(f"  g = {g:.3f}  →  V_crit ≈ {p['V_trap']:.5f}")
                    break
    return {"collapse_fraction": collapsed / total}

def analyze_collision(coll):
    print("\n" + "="*92)
    print("📌 4. 双环碰撞动力学分类")
    print("="*92)
    if not coll:
        return {}
    type_count = defaultdict(int)
    for r in coll:
        type_count[r['type']] += 1
    print("碰撞类型分布：")
    for t in ['quasi-elastic', 'fusion', 'fragmentation', 'collapse', 'transition', 'numerical_fragmentation']:
        if t in type_count:
            print(f"  {t:22s} : {type_count[t]:2d} 次 ({type_count[t]/len(coll)*100:5.1f}%)")
    print("\n详细数据（按 k0 排序）：")
    print(f"{'k0':>6}  {'类型':22}  {'ρ_ratio':>8}  {'峰数':>6}  {'径向相关':>10}  {'dt_used':>8}")
    print("-" * 88)
    for r in sorted(coll, key=lambda x: x['k0']):
        print(f"{r['k0']:6.2f}  {r['type']:22s}  {r['rho_ratio']:8.3f}  "
              f"{r['n_peaks']:6d}  {r['radial_corr']:10.3f}  {safe_get(r, 'dt_used', 'N/A'):>8}")
    return {"type_counts": dict(type_count)}

