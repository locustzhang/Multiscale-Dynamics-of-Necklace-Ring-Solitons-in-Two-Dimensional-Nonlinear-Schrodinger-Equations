def plot_fig8():
    """修改为 2x2 网格，并添加 (a)-(d) 标签"""
    types_present = list({r['type'] for r in collision_scan})
    ordered = ['quasi-elastic', 'fusion', 'fragmentation', 'collapse',
               'transition', 'numerical_fragmentation']
    types_show = [t for t in ordered if t in types_present]
    # 如果不足4种，用 None 填充以达到2x2布局
    while len(types_show) < 4:
        types_show.append(None)

    shown = {}
    for r in collision_scan:
        ct = r['type']
        if ct not in shown:
            snaps = find_snaps(f"coll_k0_{r['k0']:.2f}")
            if snaps:
                shown[ct] = {'snap': snaps[-1], 't': r['t'][-1], 'k0': r['k0']}

    fig = plt.figure(figsize=(14, 10))
    gs = GridSpec(2, 2, wspace=0.15, hspace=0.25, left=0.06, right=0.94, top=0.92, bottom=0.05)
    letters = ['a', 'b', 'c', 'd']
    for idx, ct in enumerate(types_show[:4]):  # 最多取前4个
        ax = fig.add_subplot(gs[idx//2, idx%2])
        if ct is None or ct not in shown:
            # 空白占位，显示提示
            ax.text(0.5, 0.5, 'No data', transform=ax.transAxes,
                    ha='center', va='center', fontsize=12, color='grey')
            ax.set_title(f"({letters[idx]}) N/A")
            ax.set_xticks([]); ax.set_yticks([])
            style_ax(ax)
            continue
        info = shown[ct]
        z = np.load(info['snap'])
        ext = [-15, 15, -15, 15]
        density_panel(ax, z, info['t'], ext, letters[idx])
        ax.set_title(f"{ct}  ($k_0$={info['k0']:.1f})", fontsize=12,
                     color=COLL_COLORS.get(ct, 'black'), fontweight='bold', pad=8)
        ax.set_xlim(-15*0.65, 15*0.65)
        ax.set_ylim(-15*0.65, 15*0.65)
    fig.savefig(os.path.join(OUTPUT_DIR, 'Fig8_CollisionSnapshots.pdf'), bbox_inches='tight')
    plt.close()
    print("✅ Fig8_CollisionSnapshots.pdf (2x2 布局)")

