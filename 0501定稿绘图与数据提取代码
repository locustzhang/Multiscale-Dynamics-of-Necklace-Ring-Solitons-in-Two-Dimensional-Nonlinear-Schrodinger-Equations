def plot_fig4():
    snaps = find_snaps("SingleRing")
    if not snaps:
        print("⚠️  缺少单环快照，跳过 Fig4")
        return
    Lx = 25.0
    n_plot = len(snaps)
    t_vals = np.linspace(0, 6.0, n_plot)
    r_bins = np.linspace(0, Lx, RADIAL_PROFILE_BINS+1)
    r_centers = 0.5*(r_bins[:-1] + r_bins[1:])
    rho_rt = np.zeros((RADIAL_PROFILE_BINS, n_plot))
    snap0 = np.load(snaps[0])
    Ny, Nx = snap0.shape
    x = np.linspace(-Lx, Lx, Nx)
    y = np.linspace(-Lx, Lx, Ny)
    X, Y = np.meshgrid(x, y, indexing='ij')
    R = np.sqrt(X**2 + Y**2).ravel()
    for i, f in enumerate(snaps):
        z = np.load(f)
        rho = np.abs(z)**2
        hist, _ = np.histogram(R, bins=r_bins, weights=rho.ravel())
        cnt, _ = np.histogram(R, bins=r_bins)
        with np.errstate(divide='ignore', invalid='ignore'):
            rho_rt[:, i] = np.where(cnt>0, hist/cnt, 0.0)

    gs_plot = np.array([r['g'] for r in scan1d])
    rho_ratio = np.array([r['rho_ratio'] for r in scan1d])
    n_free = np.array([r.get('N_over_Ncr_free', r.get('N_overNcr_free', np.nan)) for r in scan1d])
    n_trap = np.array([r.get('N_over_Ncr_trap', r.get('N_overNcr_trap', np.nan)) for r in scan1d])
    valid = np.array([r.get('N_cr_trap_valid', True) for r in scan1d])

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(13, 5))
    im = ax1.pcolormesh(t_vals, r_centers, rho_rt, cmap=plt.cm.magma,
                        norm=PowerNorm(gamma=0.5), shading='gouraud')
    cbar = plt.colorbar(im, ax=ax1, label=r'$\langle|\psi|^2\rangle_\theta$')
    cbar.outline.set_visible(False)
    ax1.axhline(8.0, color='white', ls='--', lw=0.9, alpha=0.7)
    ax1.set_xlabel('Time $t$'); ax1.set_ylabel('Radius $r$')
    ax1.set_title('(a) Azimuthal-mean density $\\rho(r,t)$', pad=10)
    style_ax(ax1); panel_label(ax1, 'a', y=1.06)

    ax2.plot(gs_plot, rho_ratio, 'o-', color=C['blue'], lw=1.8, ms=6,
             label=r'$\rho_{\mathrm{max}}(T)/\rho_{\mathrm{max}}(0)$')
    ax2_r = ax2.twinx()
    ax2_r.plot(gs_plot, n_free, 's--', color=C['grey'], lw=1, ms=4, alpha=0.6,
               label=r'$N/N_{\mathrm{cr}}^{\mathrm{free}}$')
    ax2_r.plot(gs_plot[valid], n_trap[valid], 'D-', color=C['orange'], lw=1.2, ms=5, alpha=0.8,
               label=r'$N/N_{\mathrm{cr}}^{\mathrm{trap}}$ (valid)')
    if np.any(~valid):
        ax2_r.plot(gs_plot[~valid], n_trap[~valid], 'D:', color=C['orange'], lw=1, ms=4, alpha=0.4)
    ax2_r.axhline(1.0, color=C['red'], ls=':', lw=0.9)
    ax2.set_xlabel(r'$g$'); ax2.set_ylabel(r'$\rho_{\mathrm{max}}$ ratio')
    ax2_r.set_ylabel(r'$N/N_{\mathrm{cr}}$', color=C['grey'])
    ax2_r.tick_params(axis='y', labelcolor=C['grey'])
    lines = ax2.get_legend_handles_labels()[0] + ax2_r.get_legend_handles_labels()[0]
    labs  = ax2.get_legend_handles_labels()[1] + ax2_r.get_legend_handles_labels()[1]
    ax2.legend(lines, labs, fontsize=7.5, loc='upper left')
    ax2.set_title('(b) Stability vs $g$', pad=10)
    style_ax(ax2); panel_label(ax2, 'b', y=1.06)
    fig.savefig(os.path.join(OUTPUT_DIR, 'Fig4_Stability.pdf'), bbox_inches='tight')
    plt.close()
    print("✅ Fig4_Stability.pdf")

def plot_fig5():
    dt_res = convergence.get("dt_results", [])
    nx_res = convergence.get("nx_results", [])
    fig, (ax1, ax2) = plt.subplots(1,2, figsize=(12,5))
    if dt_res:
        dts = np.array([r['dt'] for r in dt_res])
        sol = np.array([r['sol_err'] for r in dt_res])
        idx = np.argsort(dts)[::-1]
        dts, sol = dts[idx], sol[idx]
        ax1.loglog(dts, sol, '^-', color=C['teal'], lw=2, ms=8)
        mask = sol > 1e-14
        if mask.sum() >= 2:
            slope, intercept = np.polyfit(np.log10(dts[mask]), np.log10(sol[mask]), 1)
            dt_fit = np.geomspace(dts[mask].min(), dts[mask].max(), 80)
            ax1.loglog(dt_fit, 10**intercept * dt_fit**slope, '--', color=C['grey'])
        ref2 = sol[0] * (dts / dts[0])**2
        ax1.loglog(dts, ref2, ':', color=C['red'], label=r'$\mathcal{O}(\Delta t^2)$')
        ax1.set_xlabel(r'$\Delta t$'); ax1.set_ylabel('Solution error')
        # 关键修改：增加 title pad 避免与 (a) 标签重叠
        ax1.set_title('Temporal convergence (BAB Strang splitting, 2nd order)', pad=12)
        ax1.legend(fontsize=9)
        style_ax(ax1); panel_label(ax1, 'a', y=1.10)    # 标签上移
    if nx_res:
        dxs = np.array([r['dx'] for r in nx_res])
        err = np.array([r['E_err'] for r in nx_res])
        idx = np.argsort(dxs)[::-1]
        ax2.loglog(dxs[idx], err[idx], 's-', color=C['red'], lw=2, ms=8, label='Energy error')
        ax2.set_xlabel(r'$\Delta x$'); ax2.set_ylabel('Energy error')
        ax2.set_title('Spatial convergence (pseudo-spectral)', pad=12)
        ax2.legend(fontsize=9)
        style_ax(ax2); panel_label(ax2, 'b', y=1.10)
    fig.savefig(os.path.join(OUTPUT_DIR, 'Fig5_Convergence.pdf'), bbox_inches='tight')
    plt.close()
    print("✅ Fig5_Convergence.pdf")

def plot_fig6():
    G_grid = np.array([scan2d[i][0]['g'] for i in range(len(scan2d))])
    V_grid = np.array([scan2d[0][j]['V_trap'] for j in range(len(scan2d[0]))])
    nG, nV = len(G_grid), len(V_grid)
    rho_mat = np.zeros((nG, nV))
    coll_mat = np.zeros((nG, nV))
    nocr_mat = np.zeros((nG, nV))
    valid_mat = np.ones((nG, nV), dtype=bool)
    for i in range(nG):
        for j in range(nV):
            p = scan2d[i][j]
            rho_mat[i,j] = p['rho_ratio']
            coll_mat[i,j] = 1.0 if p.get('collapsed', False) else 0.0
            nocr_mat[i,j] = p.get('N_over_Ncr_trap', p.get('N_overNcr_trap', np.nan))
            valid_mat[i,j] = p.get('N_cr_trap_valid', True)

    fig, (ax1, ax2, ax3) = plt.subplots(1,3, figsize=(15,5))
    ext = [V_grid.min(), V_grid.max(), G_grid.min(), G_grid.max()]

    vmin_pos = rho_mat[rho_mat>0].min() if np.any(rho_mat>0) else 1e-3
    im1 = ax1.imshow(rho_mat, origin='lower', aspect='auto', cmap=plt.cm.magma,
                     norm=LogNorm(vmin=vmin_pos, vmax=rho_mat.max()), extent=ext)
    cbar1 = plt.colorbar(im1, ax=ax1, label=r'$\rho_{\mathrm{max}}(T)/\rho_{\mathrm{max}}(0)$')
    cbar1.ax.yaxis.set_major_locator(LogLocator(subs='all'))
    ax1.set_xlabel(r'$V_{\mathrm{trap}}$'); ax1.set_ylabel(r'$g$')
    ax1.set_title('(a) Peak density ratio (log scale)')
    style_ax(ax1)

    cmap_bin = mcolors.ListedColormap(['#2196F3', '#F44336'])
    im2 = ax2.imshow(coll_mat, origin='lower', aspect='auto', cmap=cmap_bin,
                     vmin=0, vmax=1, extent=ext)
    if np.any(coll_mat) and np.any(1-coll_mat):
        ax2.contour(V_grid, G_grid, coll_mat, levels=[0.5], colors='white', linewidths=1.5)
    ax2.legend(handles=[mpatches.Patch(color='#2196F3', label='Stable'),
                        mpatches.Patch(color='#F44336', label='Collapsed')])
    ax2.set_xlabel(r'$V_{\mathrm{trap}}$'); ax2.set_ylabel(r'$g$')
    ax2.set_title('(b) Stability phase diagram')
    style_ax(ax2)

    im3 = ax3.imshow(nocr_mat, origin='lower', aspect='auto', cmap=plt.cm.viridis,
                     extent=ext, vmin=0, vmax=3)
    ax3.axhline(y=-0.08, color='red', ls='--', lw=1.0)
    invalid_mask = ~valid_mat
    if np.any(invalid_mask):
        invalid_disp = np.where(invalid_mask, 1.0, np.nan)
        ax3.imshow(invalid_disp, origin='lower', aspect='auto',
                   cmap=mcolors.ListedColormap(['#ffffff00', '#ffffff']),
                   alpha=0.35, extent=ext)
    plt.colorbar(im3, ax=ax3, label=r'$N/N_{\mathrm{cr}}^{\mathrm{trap}}$')
    ax3.set_xlabel(r'$V_{\mathrm{trap}}$'); ax3.set_ylabel(r'$g$')
    ax3.set_title(r'(c) $N/N_{\mathrm{cr}}^{\mathrm{trap}}$')
    style_ax(ax3)
    fig.savefig(os.path.join(OUTPUT_DIR, 'Fig6_PhaseDiagram.pdf'), bbox_inches='tight')
    plt.close()
    print("✅ Fig6_PhaseDiagram.pdf (色彩优化)")

